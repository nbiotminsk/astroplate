---
import Base from "@/layouts/Base.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
---

<style is:global>
  .qty-control {
    display: flex;
    align-items: center;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 6px;
    overflow: hidden;
    height: 28px;
    background: white;
    width: fit-content;
  }
  .dark .qty-control {
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
  }
  .qty-btn {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: rgba(0, 0, 0, 0.03);
    cursor: pointer;
    font-size: 16px;
    transition: background 0.2s;
    padding: 0;
    margin: 0;
  }
  .dark .qty-btn {
    background: rgba(255, 255, 255, 0.05);
    color: white;
  }
  .qty-btn:hover {
    background: rgba(0, 0, 0, 0.08);
  }
  .dark .qty-btn:hover {
    background: rgba(255, 255, 255, 0.1);
  }
  .qty-input {
    width: 32px !important;
    min-width: 32px !important;
    max-width: 32px !important;
    height: 26px !important;
    min-height: 26px !important;
    text-align: center;
    border: none !important;
    font-weight: 700;
    font-size: 14px;
    background: transparent !important;
    appearance: textfield;
    padding: 0 !important;
    margin: 0 4px 0 0 !important;
    outline: none !important;
    box-shadow: none !important;
    display: block !important;
    -moz-appearance: textfield;
  }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
</style>

<Base title="Корзина" description="Ваша корзина товаров" hideBreadcrumbs={true}>
  <section class="section pb-8 pt-6">
    <div class="container">
      <Breadcrumbs className="mb-6" title="Корзина" />
      <h1 class="mb-8 h2">Ваша корзина</h1>

      <div class="row">
        <div class="lg:col-8">
          <div
            class="rounded border border-border bg-light p-6 dark:border-darkmode-border dark:bg-darkmode-light"
          >
            <div id="cart-page-items" class="min-h-[100px]">
              <!-- Items will be rendered here by script -->
              <p class="animate-pulse text-center">Загрузка корзины...</p>
            </div>
          </div>
        </div>

        <div class="lg:col-4">
          <div
            class="sticky top-24 rounded border border-border bg-light p-6 dark:border-darkmode-border dark:bg-darkmode-light"
          >
            <h3 class="mb-6 h4">Итого</h3>
            <div
              class="mb-4 flex justify-between border-b border-border pb-4 dark:border-darkmode-border"
            >
              <span>Всего товаров:</span>
              <span id="cart-page-count" class="font-bold">0</span>
            </div>
            <div class="mb-8 flex justify-between text-xl">
              <span>Сумма:</span>
              <span id="cart-page-total" class="font-bold text-emerald-600"
                >0 BYN</span
              >
            </div>
            <div class="flex flex-col gap-4">
              <button
                id="checkout-btn"
                class="btn btn-primary w-full text-center"
                >Перейти к оформлению</button
              >
              <p class="mt-2 text-center text-[11px] leading-tight text-text-light dark:text-darkmode-text-light">
                Нажимая кнопку, вы принимаете условия <a href="/info/dogovor-oferty" class="underline hover:text-primary">договора публичной оферты</a>
              </p>
              <button
                id="clear-cart-page"
                class="btn btn-outline-primary w-full">Очистить корзину</button
              >
              <a href="/store" class="btn btn-link w-full text-center"
                >Вернуться в магазин</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import {
    getCart,
    getCartTotal,
    getCartCount,
    removeFromCart,
    updateQuantity,
    clearCart,
  } from "@/lib/cart";

  const renderCartPage = () => {
    const itemsWrap = document.getElementById("cart-page-items");
    const countEl = document.getElementById("cart-page-count");
    const totalEl = document.getElementById("cart-page-total");

    if (!itemsWrap) return;

    const cart = getCart();
    const count = getCartCount();
    const total = getCartTotal();

    if (countEl) countEl.textContent = count.toString();
    if (totalEl) totalEl.textContent = `${total} BYN`;

    if (cart.length === 0) {
      itemsWrap.innerHTML = `
        <div class="py-8 text-center">
          <p class="mb-6 text-lg text-text-light dark:text-darkmode-text-light">Ваша корзина пуста</p>
          <a href="/store" class="btn btn-primary">Перейти в магазин</a>
        </div>
      `;
      return;
    }

    itemsWrap.innerHTML = cart
      .map(
        (item) => `
        <div class="mb-6 flex flex-wrap items-center justify-between gap-4 border-b border-border pb-6 last:mb-0 last:border-0 last:pb-0 dark:border-darkmode-border">
          <div class="flex items-center gap-4">
            <div class="flex-1">
              <h4 class="mb-1 text-lg font-semibold">${item.title}</h4>
              <p class="mb-0 text-sm text-text-light dark:text-darkmode-text-light">${item.price} BYN за шт.</p>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:24px;">
            <div class="qty-control">
              <button class="qty-btn" data-dec="${item.id}">-</button>
              <input 
                type="number" 
                value="${item.quantity}" 
                min="1" 
                class="qty-input" 
                data-qty-input="${item.id}"
              />
              <button class="qty-btn" data-inc="${item.id}">+</button>
            </div>
            <div style="min-width:80px;text-align:right;font-weight:700;">
              ${item.price * item.quantity} BYN
            </div>
            <button class="text-red-500 hover:text-red-700 transition" aria-label="Удалить" data-remove="${item.id}">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18m-2 0v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6m3 0V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
            </button>
          </div>
        </div>
      `,
      )
      .join("");

    // Add listners
    itemsWrap.querySelectorAll("[data-remove]").forEach((btn) => {
      btn.addEventListener("click", () => {
        removeFromCart((btn as HTMLElement).dataset.remove || "");
        renderCartPage();
      });
    });

    itemsWrap.querySelectorAll("[data-inc]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = (btn as HTMLElement).dataset.inc || "";
        const item = getCart().find((i) => i.id === id);
        if (item) updateQuantity(id, item.quantity + 1);
        renderCartPage();
      });
    });

    itemsWrap.querySelectorAll("[data-dec]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = (btn as HTMLElement).dataset.dec || "";
        const item = getCart().find((i) => i.id === id);
        if (item) updateQuantity(id, item.quantity - 1);
        renderCartPage();
      });
    });

    itemsWrap.querySelectorAll("[data-qty-input]").forEach((input) => {
      input.addEventListener("change", (e) => {
        const id = (input as HTMLElement).dataset.qtyInput || "";
        const val = parseInt((e.target as HTMLInputElement).value);
        updateQuantity(id, val);
        renderCartPage();
      });
    });
  };
  const init = () => {
    if ((window as any)._cartInitialized) return;
    (window as any)._cartInitialized = true;

    const clearBtn = document.getElementById("clear-cart-page");
    if (clearBtn) {
      clearBtn.addEventListener("click", () => {
        clearCart();
        renderCartPage();
      });
    }

    const checkoutBtn = document.getElementById("checkout-btn");
    if (checkoutBtn) {
      checkoutBtn.addEventListener("click", () => {
        document.dispatchEvent(new CustomEvent("checkout:open"));
      });
    }
    renderCartPage();

    // Listen for cart updates from other components
    window.addEventListener("cart:update", renderCartPage);
    document.addEventListener("cart:update", renderCartPage);
  };

  // Run on page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  window.addEventListener("pageshow", () => {
    init();
  });
</script>
