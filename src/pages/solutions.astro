---
import BlogCard from "@/components/BlogCard.astro";
import CallToAction from "@/components/CallToAction.astro";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import PageHeader from "@/partials/PageHeader.astro";

const posts = await getSinglePage("blog");
const sortedPosts = sortByDate(posts);
const allCategories = Array.from(
  new Set(sortedPosts.flatMap((post) => post.data.categories || [])),
).sort((a, b) => a.localeCompare(b));
const allTags = Array.from(
  new Set(sortedPosts.flatMap((post) => post.data.tags || [])),
).sort((a, b) => a.localeCompare(b));
---

<Base
  title="Решения"
  meta_title="Решения"
  description="Решения и статьи из блога"
>
  <PageHeader title="Решения" compact={true} />

  <section class="py-8 xl:py-10">
    <div class="container">
      {
        sortedPosts.length ? (
          <>
            <div class="mb-8 flex flex-wrap items-center gap-4">
              <div class="flex items-center gap-2">
                <span
                  class="inline-flex text-dark dark:text-white"
                  aria-hidden="true"
                >
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
                    <path
                      d="M3 7H21M7 12H17M10 17H14"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                    />
                  </svg>
                </span>
                <select
                  id="solutions-category-filter"
                  aria-label="Фильтр по категории"
                  class="rounded border border-border bg-light px-3 py-2 text-sm dark:bg-darkmode-light"
                >
                  <option value="">Все категории</option>
                  {allCategories.map((category) => (
                    <option value={category}>{category}</option>
                  ))}
                </select>
              </div>
              <div class="flex items-center gap-2">
                <span
                  class="inline-flex text-dark dark:text-white"
                  aria-hidden="true"
                >
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
                    <path
                      d="M3 12L11 20L21 10L13 2H5V10L3 12Z"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linejoin="round"
                    />
                    <circle cx="8.5" cy="8.5" r="1.2" fill="currentColor" />
                  </svg>
                </span>
                <select
                  id="solutions-tag-filter"
                  aria-label="Фильтр по тегу"
                  class="rounded border border-border bg-light px-3 py-2 text-sm dark:bg-darkmode-light"
                >
                  <option value="">Все теги</option>
                  {allTags.map((tag) => (
                    <option value={tag}>{tag}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="row" id="solutions-grid">
              {sortedPosts.map((post) => (
                <div
                  class="mb-14 md:col-6 xl:col-4"
                  data-categories={(post.data.categories || []).join("|")}
                  data-tags={(post.data.tags || []).join("|")}
                >
                  <BlogCard data={post} />
                </div>
              ))}
            </div>
          </>
        ) : (
          <p>Статей пока нет.</p>
        )
      }
      <CallToAction />
    </div>
  </section>
</Base>

<script>
  const initSolutionsFilters = () => {
    const categoryFilter = document.querySelector(
      "#solutions-category-filter",
    ) as HTMLSelectElement | null;
    const tagFilter = document.querySelector(
      "#solutions-tag-filter",
    ) as HTMLSelectElement | null;
    const cards = Array.from(
      document.querySelectorAll("#solutions-grid > [data-categories]"),
    ) as HTMLElement[];

    if (!categoryFilter && !tagFilter) return;

    const applyFilters = () => {
      const selectedCategory = categoryFilter?.value || "";
      const selectedTag = tagFilter?.value || "";

      cards.forEach((card) => {
        const categories = String(card.dataset.categories || "")
          .split("|")
          .filter(Boolean);
        const tags = String(card.dataset.tags || "")
          .split("|")
          .filter(Boolean);

        const categoryMatch =
          !selectedCategory || categories.includes(selectedCategory);
        const tagMatch = !selectedTag || tags.includes(selectedTag);
        card.style.display = categoryMatch && tagMatch ? "" : "none";
      });
    };

    categoryFilter?.addEventListener("change", applyFilters);
    tagFilter?.addEventListener("change", applyFilters);
    applyFilters();
  };

  document.addEventListener("DOMContentLoaded", initSolutionsFilters);
  initSolutionsFilters();
</script>
