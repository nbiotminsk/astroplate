---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import PageHeader from "@/partials/PageHeader.astro";
import { render } from "astro:content";
import ImageMod from "@/components/ImageMod.astro";
import JsonLd from "@/components/JsonLd.astro";

// get static paths for all pages
export async function getStaticPaths() {
  const COLLECTION_FOLDER = "pages";

  const pages = await getSinglePage(COLLECTION_FOLDER);

  const paths = pages.map((page) => ({
    params: {
      regular: page.id,
    },
    props: { page },
  }));
  return paths;
}

const { page } = Astro.props;
const { title, meta_title, description, image, faq } = page.data;
const { Content } = await render(page);

const faqSchema =
  faq && faq.length > 0
    ? {
        mainEntity: faq.map((item: any) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : null;
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  {faqSchema && <JsonLd slot="head" type="FAQPage" data={faqSchema} />}
  <PageHeader title={title} />
  <section class="section-sm">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-10">
          {
            image && (
              <div class="mb-10 flex justify-center">
                <ImageMod
                  src={image}
                  height={500}
                  width={1200}
                  alt={title}
                  class="rounded object-contain max-h-[500px] w-full"
                  format="webp"
                />
              </div>
            )
          }
          <div class="content">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { addToCart } from "@/lib/cart";

  const initServiceButtons = () => {
    const buttons = document.querySelectorAll("[data-order-service]");
    buttons.forEach((btn) => {
      if ((btn as HTMLElement).dataset.initialized) return;
      (btn as HTMLElement).dataset.initialized = "true";

      btn.addEventListener("click", () => {
        const id = (btn as HTMLElement).dataset.orderService;
        const title = (btn as HTMLElement).dataset.title;
        const price = Number((btn as HTMLElement).dataset.price);

        if (id && title && !isNaN(price)) {
          addToCart({ id, title, price, quantity: 1 });
          document.dispatchEvent(new CustomEvent("cart:item-added"));
        }
      });
    });
  };

  // Run on load and after swaps (if using view transitions)
  initServiceButtons();
  document.addEventListener("astro:page-load", initServiceButtons);
</script>
