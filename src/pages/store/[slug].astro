---
import ImageMod from "@/components/ImageMod.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import CallToAction from "@/components/CallToAction.astro";
import JsonLd from "@/components/JsonLd.astro";
import { getNormalizedCollection } from "@/lib/contentCollections";
import {
  getStoreLabelMeta,
  normalizeStoreLabel,
} from "@/lib/utils/storeLabels";
import { render } from "astro:content";

export async function getStaticPaths() {
  const catalogEntries = await getNormalizedCollection(
    "store",
    ({ data }) => !data.draft,
  );

  return catalogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { product: entry },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const title = product.data.title;
const category = product.data.category || "others";
const image =
  product.data.img || product.data.image || "/images/image-placeholder.png";
const description = (
  product.data.description ||
  product.data.short_description ||
  ""
).slice(0, 5000);

// SEO Enhancement
const metaTitle = product.data.meta_title || `${title} | Купить в Минске`;
const isNbiot =
  category.toLowerCase().includes("nbiot") ||
  title.toLowerCase().includes("nbiot");
const isMeter =
  category.toLowerCase().includes("счетчик") ||
  category.toLowerCase().includes("счётчик") ||
  title.toLowerCase().includes("счетчик") ||
  title.toLowerCase().includes("счётчик");
const isKit =
  category.toLowerCase().includes("комплект") ||
  title.toLowerCase().includes("комплект");
const isHeat =
  category.toLowerCase().includes("тепл") ||
  title.toLowerCase().includes("тепл") ||
  description.toLowerCase().includes("тепл");
const keyPhrases = [
  isNbiot ? "модуль NBIoT для учёта воды" : "",
  isHeat ? "модуль для учета тепла" : "",
  "дистанционный учёт воды",
].filter(Boolean);

const metaDescription =
  product.data.meta_description ||
  `${title}${category !== "others" ? ` (${category})` : ""}. ${keyPhrases.length > 0 ? `${keyPhrases.join(", ")}. ` : ""}Доступная цена, доставка по Минску и Беларуси. Заказывайте на teleofis24.by!`;

const features = product.data.features || [];
const brand = product.data.brand || "Teleofis24";
const priceNumber = Number(product.data.price ?? 0);
const price = Number.isNaN(priceNumber) ? 0 : priceNumber;
const isInStock = product.data.availability !== false;
const customLabel = normalizeStoreLabel(product.data.custom_label_0);
const labelMeta = getStoreLabelMeta(customLabel);
const availabilitySchema = isInStock
  ? "https://schema.org/InStock"
  : "https://schema.org/OutOfStock";
const gtin = product.data.gtin || product.data.gtin13 || product.data.gtin14;

const siteUrl = config.site.base_url.replace(/\/$/, "");
const productUrl = `${siteUrl}/store/${product.id}/`;
const imageUrl = `${siteUrl}${image}`;

const productFaqs = [
  {
    question: `Как купить ${title} для организации?`,
    answer:
      "Мы работаем с юридическими лицами по безналичному расчету. Вы можете отправить запрос на info@teleofis24.by для получения счета или оставить заявку через форму контактов.",
  },
  {
    question: "Есть ли гарантия на оборудование?",
    answer:
      "Да, на всё оборудование предоставляется официальная гарантия 12 месяцев. Мы также обеспечиваем техническую поддержку и консультации по настройке.",
  },
  {
    question: "Возможен ли монтаж и подключение?",
    answer:
      "Да, наши специалисты выполняют монтаж, пусконаладку и подключение к платформам мониторинга (например, 'Мой Клиент: Ресурсы').",
  },
];

// Extract SKU and MPN safely (handle objects from Sitepins)
const rawSku = product.data.sku;
const sku =
  typeof rawSku === "object" && rawSku !== null
    ? (rawSku as any).value || (rawSku as any).id || product.id
    : rawSku || product.id;

const rawMpn = product.data.mpn;
const mpn =
  typeof rawMpn === "object" && rawMpn !== null
    ? (rawMpn as any).value || (rawMpn as any).id || product.id
    : rawMpn || product.id;

// Google Rich Results - Merchant Center requirements
const productSchema = {
  "@id": `${productUrl}#product`,
  name: title.slice(0, 150),
  description,
  image: [
    {
      "@type": "ImageObject",
      url: imageUrl,
      caption: title,
      description: title,
    },
  ],
  sku: String(sku).slice(0, 100),
  mpn: String(mpn).slice(0, 100),
  category,
  brand: {
    "@type": "Brand",
    name: String(brand).slice(0, 70),
  },
  itemCondition: product.data.condition || "https://schema.org/NewCondition",
  ...(product.data.aggregateRating &&
  product.data.aggregateRating.reviewCount > 0
    ? {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: product.data.aggregateRating.ratingValue,
          reviewCount: product.data.aggregateRating.reviewCount,
          bestRating: product.data.aggregateRating.bestRating || 5,
        },
      }
    : {}),
  ...(product.data.review
    ? {
        review: {
          "@type": "Review",
          reviewRating: {
            "@type": "Rating",
            ratingValue: product.data.review.rating,
            bestRating: 5,
          },
          author: {
            "@type": "Person",
            name: "Покупатель",
          },
        },
      }
    : {}),
  additionalProperty: features.map((feature, index) => ({
    "@type": "PropertyValue",
    name: `Характеристика ${index + 1}`,
    value: feature,
  })),
  ...(gtin ? { gtin } : {}),
  offers: {
    "@type": "Offer",
    url: productUrl,
    price: price.toFixed(2),
    priceCurrency: "BYN",
    availability: availabilitySchema,
    itemCondition: product.data.condition || "https://schema.org/NewCondition",
    priceValidUntil: "2027-12-31",
    seller: {
      "@type": "Organization",
      name: "Teleofis24",
      url: siteUrl,
    },
    shippingDetails: {
      "@type": "OfferShippingDetails",
      shippingRate: {
        "@type": "MonetaryAmount",
        value: "0",
        currency: "BYN",
      },
      shippingDestination: {
        "@type": "DefinedRegion",
        addressCountry: "BY",
      },
      deliveryTime: {
        "@type": "ShippingDeliveryTime",
        handlingTime: {
          "@type": "QuantitativeValue",
          minValue: 0,
          maxValue: 1,
          unitCode: "DAY",
        },
        transitTime: {
          "@type": "QuantitativeValue",
          minValue: 1,
          maxValue: 3,
          unitCode: "DAY",
        },
      },
    },
    hasMerchantReturnPolicy: {
      "@type": "MerchantReturnPolicy",
      applicableCountry: "BY",
      returnPolicyCategory:
        "https://schema.org/MerchantReturnFiniteReturnWindow",
      merchantReturnDays: 14,
      returnMethod: "https://schema.org/ReturnByMail",
      returnFees: "https://schema.org/FreeReturn",
    },
  },
};
---

<Base
  title={title}
  meta_title={metaTitle as string}
  description={metaDescription as string}
  image={image}
  canonical={productUrl}
>
  <Fragment slot="head">
    <meta property="og:type" content="product" />
    <meta property="product:price:amount" content={price.toFixed(2)} />
    <meta property="product:price:currency" content="BYN" />
    <meta
      property="product:availability"
      content={isInStock ? "in stock" : "out of stock"}
    />
    <JsonLd type="Product" data={productSchema} />
    <JsonLd
      type="FAQPage"
      data={{
        mainEntity: productFaqs.map((faq) => ({
          "@type": "Question",
          name: faq.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
          },
        })),
      }}
    />
  </Fragment>
  <section class="section pb-8 pt-6">
    <div class="container">
      <Breadcrumbs className="mb-4" title={title} />
      <a href="/store/" class="mb-6 inline-block text-primary underline">
        ← Назад в магазин
      </a>
      <div class="row items-start gap-y-8">
        <div class="lg:col-6">
          <ImageMod
            class="w-full rounded border border-border dark:border-darkmode-border"
            src={image}
            alt={title}
            width={620}
            height={420}
            format="webp"
          />
        </div>
        <div class="lg:col-6">
          <div class="mb-3 flex flex-wrap gap-2">
            <p
              class="inline-flex rounded bg-light px-3 py-1 text-xs dark:bg-darkmode-light"
            >
              {category}
            </p>
            {
              labelMeta ? (
                <span
                  class={`inline-flex rounded border px-3 py-1 text-xs font-semibold ${labelMeta.className}`}
                >
                  {labelMeta.badge}
                </span>
              ) : null
            }
          </div>
          <h1 class="mb-3">{title}</h1>
          <p
            class={`mb-4 text-3xl font-bold ${
              customLabel === "premium"
                ? "text-amber-700 dark:text-amber-300"
                : customLabel === "discount"
                  ? "text-rose-600 dark:text-rose-300"
                  : "text-emerald-600"
            }`}
          >
            {price} BYN
          </p>
          <p
            class={`mb-4 text-sm ${isInStock ? "text-green-700" : "text-red-700"}`}
          >
            {isInStock ? "В наличии" : "Нет в наличии"}
          </p>
          {description && <p class="mb-6">{description}</p>}

          <div class="content mb-6">
            <Content />
          </div>

          {
            features.length > 0 && (
              <>
                <h4 class="mb-3">Характеристики</h4>
                <ul class="mb-8 list-disc pl-5">
                  {features.map((feature) => (
                    <li class="mb-2">{feature}</li>
                  ))}
                </ul>
              </>
            )
          }

          <!-- Services Section -->
          <div
            class="mb-6 space-y-3 rounded-xl border border-border bg-light/50 p-5 dark:border-darkmode-border dark:bg-darkmode-light/30"
          >
            <h4
              class="mb-3 text-base font-bold text-text-dark dark:text-darkmode-text-dark"
            >
              Дополнительные услуги:
            </h4>

            <div class="flex flex-col gap-4">
              {
                /* Service 1: Replacement - Only for simple meters or kits, hidden for NBIoT modules */
              }
              {
                (isKit || (isMeter && !isNbiot)) && (
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                      <div class="relative flex items-center">
                        <input
                          type="checkbox"
                          id="service-replacement"
                          class="peer h-5 w-5 cursor-pointer appearance-none rounded border-2 border-border transition-all checked:bg-primary checked:border-primary dark:border-darkmode-border"
                        />
                        <svg
                          class="pointer-events-none absolute left-1 hidden h-3 w-3 text-white peer-checked:block"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="4"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <polyline points="20 6 9 17 4 12" />
                        </svg>
                      </div>
                      <label
                        for="service-replacement"
                        class="cursor-pointer text-base font-medium text-text-dark dark:text-darkmode-text-dark"
                      >
                        Замена счетчика на объекте{" "}
                        <span class="ml-1 text-emerald-600 font-bold">
                          (80 руб)
                        </span>
                      </label>
                    </div>
                    <div class="flex items-center gap-2 ml-auto">
                      <span class="text-xs text-text-light uppercase tracking-wider">
                        Кол-во:
                      </span>
                      <input
                        type="number"
                        id="qty-replacement"
                        min="1"
                        value="1"
                        class="w-14 rounded border border-border bg-body px-2 py-1 text-sm outline-none transition-opacity focus:border-primary disabled:opacity-30 dark:border-darkmode-border dark:bg-darkmode-body"
                        disabled
                      />
                    </div>
                  </div>
                )
              }

              {
                /* Service 2: Warranty - Hidden for simple meters, shown for kits and NBIoT */
              }
              {
                (isKit || !isMeter || isNbiot) && (
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                      <div class="relative flex items-center">
                        <input
                          type="checkbox"
                          id="service-warranty"
                          class="peer h-5 w-5 cursor-pointer appearance-none rounded border-2 border-border transition-all checked:bg-primary checked:border-primary dark:border-darkmode-border"
                        />
                        <svg
                          class="pointer-events-none absolute left-1 hidden h-3 w-3 text-white peer-checked:block"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="4"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <polyline points="20 6 9 17 4 12" />
                        </svg>
                      </div>
                      <label
                        for="service-warranty"
                        class="cursor-pointer text-base font-medium text-text-dark dark:text-darkmode-text-dark"
                      >
                        Расширенная гарантия 24 мес{" "}
                        <span class="ml-1 text-emerald-600 font-bold">
                          (100 руб)
                        </span>
                      </label>
                    </div>
                    <div class="flex items-center gap-2 ml-auto">
                      <span class="text-xs text-text-light uppercase tracking-wider">
                        Кол-во:
                      </span>
                      <input
                        type="number"
                        id="qty-warranty"
                        min="1"
                        value="1"
                        class="w-14 rounded border border-border bg-body px-2 py-1 text-sm outline-none transition-opacity focus:border-primary disabled:opacity-30 dark:border-darkmode-border dark:bg-darkmode-body"
                        disabled
                      />
                    </div>
                  </div>
                )
              }

              {
                /* Service 3: Battery - Hidden for simple meters, shown for kits and NBIoT */
              }
              {
                (isKit || !isMeter || isNbiot) && (
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                      <div class="relative flex items-center">
                        <input
                          type="checkbox"
                          id="service-battery"
                          class="peer h-5 w-5 cursor-pointer appearance-none rounded border-2 border-border transition-all checked:bg-primary checked:border-primary dark:border-darkmode-border"
                        />
                        <svg
                          class="pointer-events-none absolute left-1 hidden h-3 w-3 text-white peer-checked:block"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="4"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <polyline points="20 6 9 17 4 12" />
                        </svg>
                      </div>
                      <label
                        for="service-battery"
                        class="cursor-pointer text-base font-medium text-text-dark dark:text-darkmode-text-dark"
                      >
                        Дополнительная батарейка{" "}
                        <span class="ml-1 text-emerald-600 font-bold">
                          (40 руб)
                        </span>
                      </label>
                    </div>
                    <div class="flex items-center gap-2 ml-auto">
                      <span class="text-xs text-text-light uppercase tracking-wider">
                        Кол-во:
                      </span>
                      <input
                        type="number"
                        id="qty-battery"
                        min="1"
                        value="1"
                        class="w-14 rounded border border-border bg-body px-2 py-1 text-sm outline-none transition-opacity focus:border-primary disabled:opacity-30 dark:border-darkmode-border dark:bg-darkmode-body"
                        disabled
                      />
                    </div>
                  </div>
                )
              }
            </div>
          </div>

          <div class="mb-4 flex items-center gap-4">
            <div class="flex items-center gap-2">
              <label
                for="detail-qty"
                class="text-sm font-semibold uppercase tracking-wider text-text-light"
                >Кол-во:</label
              >
              <input
                id="detail-qty"
                type="number"
                min="1"
                value="1"
                class="w-20 rounded-lg border border-border bg-body px-3 py-2 text-sm font-bold outline-none focus:border-primary dark:border-darkmode-border dark:bg-darkmode-body"
              />
            </div>

            <button
              type="button"
              class={`btn btn-buy flex-1 py-3 text-lg ${!isInStock ? "cursor-not-allowed opacity-50" : ""}`}
              id="add-to-cart"
              data-id={product.id}
              data-title={title}
              data-price={price}
              data-cart-category={category}
              disabled={!isInStock}
            >
              Добавить в корзину
            </button>
          </div>
        </div>
      </div>

      <!-- FAQ Section -->
      <div
        class="mt-16 border-t border-border pt-10 dark:border-darkmode-border"
      >
        <h2 class="h3 mb-8">Часто задаваемые вопросы</h2>
        <div class="space-y-4">
          {
            productFaqs.map((faq) => (
              <details class="group rounded-lg border border-border bg-light p-4 dark:border-darkmode-border dark:bg-darkmode-light">
                <summary class="flex cursor-pointer list-none items-center justify-between font-semibold text-text-dark dark:text-darkmode-text-dark">
                  <span>{faq.question}</span>
                  <span class="transition-transform group-open:rotate-180">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </span>
                </summary>
                <div class="mt-3 text-text-dark dark:text-darkmode-text">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))
          }
        </div>
      </div>

      <CallToAction />
    </div>
  </section>
</Base>

<script>
  import { addToCart } from "@/lib/cart";

  const initProductPage = () => {
    const addToCartButton = document.querySelector(
      "#add-to-cart",
    ) as HTMLButtonElement | null;
    const qtyInput = document.querySelector(
      "#detail-qty",
    ) as HTMLInputElement | null;

    if (!addToCartButton || addToCartButton.dataset.initialized === "true")
      return;
    addToCartButton.dataset.initialized = "true";

    // Services logic
    const services = [
      {
        id: "replacement",
        price: 80,
        title: "Услуга: Замена счетчика на объекте",
      },
      {
        id: "warranty",
        price: 100,
        title: "Услуга: Расширенная гарантия 24 мес",
      },
      { id: "battery", price: 40, title: "Дополнительная батарейка" },
    ];

    services.forEach((service) => {
      const checkbox = document.getElementById(
        `service-${service.id}`,
      ) as HTMLInputElement | null;
      const qty = document.getElementById(
        `qty-${service.id}`,
      ) as HTMLInputElement | null;

      if (checkbox && qty) {
        checkbox.addEventListener("change", () => {
          qty.disabled = !checkbox.checked;
          if (checkbox.checked && qtyInput) {
            qty.value = qtyInput.value;
          }
        });
      }
    });

    // Sync service quantity with main quantity if enabled
    qtyInput?.addEventListener("change", () => {
      services.forEach((service) => {
        const checkbox = document.getElementById(
          `service-${service.id}`,
        ) as HTMLInputElement | null;
        const qty = document.getElementById(
          `qty-${service.id}`,
        ) as HTMLInputElement | null;
        if (checkbox?.checked && qty) {
          qty.value = qtyInput.value;
        }
      });
    });

    addToCartButton.addEventListener("click", () => {
      const id = addToCartButton.dataset.id;
      if (!id) return;
      const title = addToCartButton.dataset.title || "";
      const price = Number(addToCartButton.dataset.price || 0);
      const category = addToCartButton.dataset.cartCategory || "";
      const quantity = Math.max(1, Number(qtyInput?.value || 1));

      // Add main product
      addToCart({ id, title, price, category, quantity });

      // Add services
      services.forEach((service) => {
        const checkbox = document.getElementById(
          `service-${service.id}`,
        ) as HTMLInputElement | null;
        const qty = document.getElementById(
          `qty-${service.id}`,
        ) as HTMLInputElement | null;

        if (checkbox?.checked) {
          const serviceQty = Math.max(1, Number(qty?.value || 1));
          addToCart({
            id: `service-${service.id}-${id}`, // Unique ID for service related to this product
            title: service.title,
            price: service.price,
            quantity: serviceQty,
          });
        }
      });

      document.dispatchEvent(new CustomEvent("cart:item-added"));
    });
  };

  const scheduleProductInit = () => {
    requestAnimationFrame(() => initProductPage());
  };

  scheduleProductInit();
  document.addEventListener("DOMContentLoaded", scheduleProductInit);
</script>
