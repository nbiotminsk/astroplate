---
import ImageMod from "@/components/ImageMod.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getNormalizedCollection } from "@/lib/contentCollections";
import { render } from "astro:content";

export async function getStaticPaths() {
  const catalogEntries = await getNormalizedCollection("store", ({ data }) => !data.draft);

  return catalogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { product: entry },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const title = product.data.title;
const category = product.data.category || "others";
const image = product.data.img || product.data.image || "/images/image-placeholder.png";
const description = product.data.description || product.data.short_description || "";
const features = product.data.features || [];
const brand = product.data.brand || "Teleofis24";
const priceNumber = Number(product.data.price ?? 0);
const price = Number.isNaN(priceNumber) ? 0 : priceNumber;
const isInStock = product.data.availability !== false;
const availabilitySchema = isInStock
  ? "https://schema.org/InStock"
  : "https://schema.org/OutOfStock";
const gtin = product.data.gtin || product.data.gtin13 || product.data.gtin14;

const siteUrl = config.site.base_url.replace(/\/$/, "");
const productUrl = `${siteUrl}/store/${product.id}`;
const imageUrl = `${siteUrl}${image}`;
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": `${productUrl}#product`,
  name: title,
  description,
  image: [imageUrl],
  sku: product.data.sku || product.id,
  mpn: product.data.mpn || product.id,
  category,
  brand: {
    "@type": "Brand",
    name: brand,
  },
  itemCondition: product.data.condition || "https://schema.org/NewCondition",
  additionalProperty: features.map((feature, index) => ({
    "@type": "PropertyValue",
    name: `Характеристика ${index + 1}`,
    value: feature,
  })),
  ...(gtin ? { gtin } : {}),
  offers: {
    "@type": "Offer",
    url: productUrl,
    price: price.toFixed(2),
    priceCurrency: "BYN",
    availability: availabilitySchema,
    itemCondition: product.data.condition || "https://schema.org/NewCondition",
    priceValidUntil: "2027-12-31",
    seller: {
      "@type": "Organization",
      name: brand,
      url: siteUrl,
    },
  },
};
---

<Base
  title={title}
  description={description}
  image={image}
  canonical={productUrl}
>
  <Fragment slot="head">
    <meta property="og:type" content="product" />
    <meta property="product:price:amount" content={price.toFixed(2)} />
    <meta property="product:price:currency" content="BYN" />
    <meta property="product:availability" content={isInStock ? "in stock" : "out of stock"} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  </Fragment>
  <section class="section pb-8 pt-6">
    <div class="container">
      <Breadcrumbs className="mb-4" title={title} />
      <a href="/store" class="mb-6 inline-block text-primary underline">
        ← Назад в магазин
      </a>
      <div class="row items-start gap-y-8">
        <div class="lg:col-6">
          <ImageMod
            class="w-full rounded border border-border dark:border-darkmode-border"
            src={image}
            alt={title}
            width={620}
            height={420}
            format="webp"
          />
        </div>
        <div class="lg:col-6">
          <p class="mb-3 inline-block rounded bg-light px-3 py-1 text-xs dark:bg-darkmode-light">
            {category}
          </p>
          <h1 class="mb-3">{title}</h1>
          <p class="mb-4 text-3xl font-bold text-emerald-600">{price} BYN</p>
          <p class={`mb-4 text-sm ${isInStock ? "text-green-700" : "text-red-700"}`}>
            {isInStock ? "В наличии" : "Нет в наличии"}
          </p>
          {description && <p class="mb-6">{description}</p>}

          <div class="content mb-6">
            <Content />
          </div>

          {
            features.length > 0 && (
              <>
                <h4 class="mb-3">Характеристики</h4>
                <ul class="mb-8 list-disc pl-5">
                  {features.map((feature) => <li class="mb-2">{feature}</li>)}
                </ul>
              </>
            )
          }

          <div class="mb-4 flex items-center gap-2">
            <label for="detail-qty" class="text-sm">Кол-во:</label>
            <input
              id="detail-qty"
              type="number"
              min="1"
              value="1"
              class="w-24 rounded border border-border bg-body px-3 py-2 text-sm dark:border-darkmode-border dark:bg-darkmode-body"
            />
          </div>

          <button
            type="button"
            class={`btn btn-buy ${!isInStock ? "cursor-not-allowed opacity-50" : ""}`}
            id="add-to-cart"
            data-id={product.id}
            data-title={title}
            data-price={price}
            disabled={!isInStock}
          >
            Купить
          </button>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { addToCart } from "@/lib/cart";

  const initProductPage = () => {
    const addToCartButton = document.querySelector(
      "#add-to-cart",
    ) as HTMLButtonElement | null;
    const qtyInput = document.querySelector("#detail-qty") as HTMLInputElement | null;

    if (!addToCartButton || addToCartButton.dataset.initialized === "true") return;
    addToCartButton.dataset.initialized = "true";

    addToCartButton.addEventListener("click", () => {
      const id = addToCartButton.dataset.id;
      if (!id) return;
      const title = addToCartButton.dataset.title || "";
      const price = Number(addToCartButton.dataset.price || 0);
      const quantity = Math.max(1, Number(qtyInput?.value || 1));

      addToCart({ id, title, price, quantity });
      document.dispatchEvent(new CustomEvent("cart:item-added"));
    });
  };

  const scheduleProductInit = () => {
    requestAnimationFrame(() => initProductPage());
  };

  scheduleProductInit();
  document.addEventListener("astro:page-load", scheduleProductInit);
</script>
