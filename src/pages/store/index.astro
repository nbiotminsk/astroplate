---
import ImageMod from "@/components/ImageMod.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Base from "@/layouts/Base.astro";
import { getNormalizedCollection } from "@/lib/contentCollections";
import {
  getStoreLabelMeta,
  getStoreLabelPriority,
  normalizeStoreLabel,
} from "@/lib/utils/storeLabels";
import { FaCrown, FaShoppingBasket } from "react-icons/fa";

const catalogEntries = await getNormalizedCollection(
  "store",
  ({ data }) => !data.draft,
);

const products = catalogEntries
  .map((entry) => {
    const priceNumber = Number(entry.data.price ?? 0);
    const label = normalizeStoreLabel(entry.data.custom_label_0);

    return {
      id: entry.id,
      title: entry.data.title,
      category: entry.data.category ?? "others",
      price: Number.isNaN(priceNumber) ? 0 : priceNumber,
      image: entry.data.img || entry.data.image || "/images/image-placeholder.png",
      availability: entry.data.availability !== false,
      customLabel: label,
      labelPriority: getStoreLabelPriority(label),
    };
  })
  .sort((a, b) => a.labelPriority - b.labelPriority || a.title.localeCompare(b.title, "ru"));

const categorySet = new Set(products.map((product) => product.category));
const tags = ["Все", ...Array.from(categorySet)];
const tagIcons: Record<string, string> = {
  Все: "M3 12h18M12 3v18",
  "Счетчики воды":
    "M12 3C8 7 6 10 6 13a6 6 0 0012 0c0-3-2-6-6-10z",
  "модули Nbiot":
    "M12 7a5 5 0 015 5M12 3a9 9 0 019 9M12 11a1 1 0 110 2 1 1 0 010-2zM4 12a8 8 0 018-8M8 12a4 4 0 014-4",
  "модули gsm":
    "M12 18v-5M8.5 14.5L12 11l3.5 3.5M6 10l6-6 6 6",
  комплекты:
    "M4 7.5L12 3l8 4.5M4 7.5V16.5L12 21l8-4.5V7.5M12 21V12",
  услуги:
    "M9 12l2 2 4-4M12 21a9 9 0 100-18 9 9 0 000 18z",
};
---

<Base title="Магазин" description="Магазин товаров с ценами и фильтрами по категориям">
  <section class="section pb-4 pt-4">
    <div class="container text-center">
      <h1 class="mb-2">Магазин</h1>
      <Breadcrumbs className="mb-4" title="Магазин" />
      <p class="mx-auto max-w-2xl">
        Выберите категорию вверху, чтобы быстро отфильтровать товары.
      </p>
    </div>
  </section>

  <section class="section pb-6 pt-0">
    <div class="container">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between">
        <div class="grid w-full grid-cols-2 gap-3 sm:flex sm:w-auto sm:flex-row sm:flex-wrap" id="catalog-tags">
          {
            tags.map((tag, index) => (
              <button
                type="button"
                class={`inline-flex min-h-[44px] w-full items-center justify-center gap-2 rounded border px-2 py-2.5 text-center text-sm transition sm:w-auto sm:justify-start sm:text-sm ${
                  index === 0
                    ? "border-primary bg-primary text-white"
                    : "border-border bg-light hover:border-primary hover:text-primary dark:bg-darkmode-light"
                }`}
                data-tag={tag}
                data-active={index === 0 ? "true" : "false"}
              >
                <svg
                  class="h-4 w-4 shrink-0"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={tagIcons[tag] ?? tagIcons["Все"]} />
                </svg>
                {tag}
              </button>
            ))
          }
        </div>
        <div class="flex items-center gap-2">
          <label for="catalog-sort" class="text-sm">Сортировка:</label>
          <select
            id="catalog-sort"
            class="rounded border border-border bg-light px-3 py-2 text-sm dark:bg-darkmode-light"
          >
            <option value="default">По умолчанию</option>
            <option value="price-asc">Цена: по возрастанию</option>
            <option value="price-desc">Цена: по убыванию</option>
            <option value="title-asc">Название: А-Я</option>
            <option value="title-desc">Название: Я-А</option>
          </select>
        </div>
      </div>

      <div class="row" id="catalog-grid">
        {
          products.map((product) => (
            <article
              class="mb-8 md:col-6 xl:col-3"
              data-category={product.category}
              data-price={product.price}
              data-title={product.title}
              data-label-priority={product.labelPriority}
              data-custom-label={product.customLabel}
            >
              <div
                class={`catalog-card group relative flex h-full flex-col rounded-2xl border bg-body p-4 shadow-sm transition hover:-translate-y-1 hover:shadow-lg dark:bg-darkmode-light ${
                  product.customLabel === "premium"
                    ? "border-amber-300 dark:border-amber-500/50"
                    : product.customLabel === "discount"
                      ? "border-emerald-300 dark:border-emerald-500/50"
                      : "border-border dark:border-darkmode-border"
                }`}
              >
                {product.customLabel === "premium" ? (
                  <div class="absolute right-4 top-4 z-10 inline-flex items-center gap-2 rounded-full border border-amber-300 bg-white/90 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-amber-800 shadow-sm backdrop-blur dark:border-amber-500/40 dark:bg-darkmode-light/90 dark:text-amber-200">
                    <FaCrown className="text-amber-500 dark:text-amber-300" />
                    <span>TOP</span>
                  </div>
                ) : product.customLabel === "discount" ? (
                  <div class="absolute right-4 top-4 z-10 inline-flex items-center gap-2 rounded-full border border-emerald-300 bg-white/90 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-emerald-800 shadow-sm backdrop-blur dark:border-emerald-500/40 dark:bg-darkmode-light/90 dark:text-emerald-200">
                    <FaShoppingBasket className="text-emerald-500 dark:text-emerald-300" />
                    <span>SALE</span>
                  </div>
                ) : null}
                <a href={`/store/${product.id}`} aria-label={`Открыть ${product.title}`}>
                  <ImageMod
                    class="catalog-card__image mb-4 h-48 w-full rounded-xl border border-border bg-light object-contain p-2 dark:border-darkmode-border dark:bg-darkmode-body"
                    src={product.image}
                    alt={product.title}
                    width={760}
                    height={440}
                    format="webp"
                  />
                </a>
                <h4 class="mb-4 min-h-[2.5rem] text-lg leading-tight">
                  {product.title}
                </h4>
                <div class="mt-auto flex flex-col gap-2 pt-4">
                  <div class="flex flex-col gap-1">
                    <p
                      class={`min-h-[2rem] text-2xl font-bold leading-none ${
                      product.customLabel === "premium"
                        ? "text-amber-700 dark:text-amber-300"
                        : product.customLabel === "discount"
                          ? "text-emerald-600 dark:text-emerald-300"
                          : "text-emerald-600"
                    }`}
                    >
                      {product.price} BYN
                    </p>
                    <p
                      class={`min-h-[1.5rem] text-sm leading-none ${
                        product.availability ? "text-green-700" : "text-red-700"
                      }`}
                    >
                      {product.availability ? "В наличии" : "Нет в наличии"}
                    </p>
                  </div>

                  <div class="flex flex-col gap-2 pt-2 sm:grid sm:grid-cols-[1fr_64px_1fr] sm:items-center sm:pt-0">
                    <button
                      type="button"
                      class={`btn btn-buy w-full text-center py-2.5 text-base sm:btn-sm sm:min-w-0 sm:px-2 sm:py-1 sm:text-sm ${
                        !product.availability ? "cursor-not-allowed opacity-50" : ""
                      }`}
                      data-add-to-cart={product.id}
                      data-price={product.price}
                      data-title={product.title}
                      data-qty-source={product.id}
                      disabled={!product.availability}
                    >
                      Купить
                    </button>
                    <input
                      id={`qty-${product.id}`}
                      type="number"
                      min="1"
                      value="1"
                      class="hidden w-full rounded border border-border bg-body px-2 py-1 text-sm dark:border-darkmode-border dark:bg-darkmode-body sm:block"
                      data-qty-input={product.id}
                    />
                    <a
                      class="btn btn-outline-primary w-full text-center py-2.5 text-base sm:btn-sm sm:min-w-0 sm:border-transparent sm:bg-transparent sm:px-2 sm:py-1 sm:text-sm sm:text-primary sm:hover:underline"
                      href={`/store/${product.id}`}
                    >
                      Подробнее
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section pt-2" id="cart">
    <div class="container">
      <div class="rounded border border-border bg-light p-5 dark:border-darkmode-border dark:bg-darkmode-light">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h3 class="mb-0">Корзина</h3>
          <span id="cart-count" class="rounded bg-body px-3 py-1 text-sm dark:bg-darkmode-body">
            0 товаров
          </span>
        </div>
        <div id="cart-items" class="mb-4"></div>
        <div class="mb-4 flex items-center justify-between border-t border-border pt-4 dark:border-darkmode-border">
          <strong>Итого:</strong>
          <strong id="cart-total">0 BYN</strong>
        </div>
        <div class="flex flex-wrap gap-3">
          <a class="btn btn-primary" href="/cart">Оформить заказ</a>
          <button id="clear-cart" type="button" class="btn btn-outline-primary">
            Очистить корзину
          </button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .catalog-card {
    transform: translateY(0);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    transition:
      transform 0.24s ease,
      box-shadow 0.24s ease,
      border-color 0.24s ease;
  }

  .catalog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 38px rgba(15, 23, 42, 0.12);
  }

  .catalog-card__image {
    transition:
      transform 0.3s ease,
      filter 0.3s ease;
  }

  .catalog-card:hover .catalog-card__image {
    transform: scale(1.02);
    filter: saturate(1.05);
  }

  #catalog-tags [data-active="true"] {
    color: #fff !important;
  }

  #catalog-tags [data-active="true"]:hover {
    color: #fff !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .catalog-card,
    .catalog-card__image {
      transition: none;
    }

    .catalog-card:hover {
      transform: none;
    }

    .catalog-card:hover .catalog-card__image {
      transform: none;
      filter: none;
    }
  }
</style>

<script>
  import {
    getCart,
    getCartTotal,
    getCartCount,
    addToCart,
    clearCart,
    removeFromCart,
    updateQuantity,
    type CartItem,
  } from "@/lib/cart";

  const initCatalogPage = () => {
    const page = document.querySelector("#catalog-grid") as HTMLElement | null;
    if (!page || page.dataset.initialized === "true") return;
    page.dataset.initialized = "true";

    const tags = document.querySelectorAll(
      "#catalog-tags [data-tag]",
    ) as NodeListOf<HTMLButtonElement>;
    const grid = document.querySelector("#catalog-grid") as HTMLElement | null;
    const sortSelect = document.querySelector(
      "#catalog-sort",
    ) as HTMLSelectElement | null;
    const cards = Array.from(
      document.querySelectorAll("#catalog-grid [data-category]"),
    ) as HTMLElement[];
    const addToCartButtons = document.querySelectorAll(
      "[data-add-to-cart]",
    ) as NodeListOf<HTMLButtonElement>;
    const cartItemsWrap = document.querySelector("#cart-items") as HTMLElement | null;
    const cartCount = document.querySelector("#cart-count") as HTMLElement | null;
    const cartTotal = document.querySelector("#cart-total") as HTMLElement | null;
    const clearCartButton = document.querySelector(
      "#clear-cart",
    ) as HTMLButtonElement | null;
    let activeTag = "Все";

    if (!grid || !sortSelect || !cartItemsWrap || !cartCount || !cartTotal || !clearCartButton) {
      return;
    }

    const formatPrice = (price: number) => `${price} BYN`;

    const renderCart = () => {
      const cart = getCart();
      const total = getCartTotal();
      const count = getCartCount();
      cartCount.textContent = `${count} товаров`;
      cartTotal.textContent = formatPrice(total);

      if (!cart.length) {
        cartItemsWrap.innerHTML = '<p class="mb-0">Корзина пуста.</p>';
        return;
      }

      cartItemsWrap.innerHTML = cart
        .map(
          (item: CartItem) => `
            <div class="mb-3 flex items-center justify-between gap-3 border-b border-border pb-3 dark:border-darkmode-border">
              <div>
                <p class="mb-1 font-semibold">${item.title}</p>
                <p class="mb-0 text-sm">${item.quantity} x ${formatPrice(item.price)}</p>
              </div>
              <div class="flex items-center gap-2">
                <button type="button" class="btn btn-outline-primary btn-sm" data-dec-item="${item.id}">-</button>
                <input
                  type="number"
                  min="1"
                  value="${item.quantity}"
                  class="w-16 rounded border border-border bg-body px-2 py-1 text-center text-sm dark:border-darkmode-border dark:bg-darkmode-body"
                  data-item-qty="${item.id}"
                />
                <button type="button" class="btn btn-outline-primary btn-sm" data-inc-item="${item.id}">+</button>
                <button type="button" class="btn btn-outline-primary btn-sm" data-remove-item="${item.id}">Удалить</button>
              </div>
            </div>
          `,
        )
        .join("");

      cartItemsWrap
        .querySelectorAll("[data-remove-item]")
        .forEach((button: Element) => {
          const btn = button as HTMLButtonElement;
          btn.addEventListener("click", () => {
            removeFromCart(btn.dataset.removeItem || "");
            renderCart();
          });
        });

      cartItemsWrap.querySelectorAll("[data-inc-item]").forEach((button: Element) => {
        const btn = button as HTMLButtonElement;
        btn.addEventListener("click", () => {
          const id = btn.dataset.incItem || "";
          const item = getCart().find((i) => i.id === id);
          if (item) updateQuantity(id, item.quantity + 1);
          renderCart();
        });
      });

      cartItemsWrap.querySelectorAll("[data-dec-item]").forEach((button: Element) => {
        const btn = button as HTMLButtonElement;
        btn.addEventListener("click", () => {
          const id = btn.dataset.decItem || "";
          const item = getCart().find((i) => i.id === id);
          if (item) updateQuantity(id, item.quantity - 1);
          renderCart();
        });
      });

      cartItemsWrap.querySelectorAll("[data-item-qty]").forEach((input: Element) => {
        const qtyInput = input as HTMLInputElement;
        qtyInput.addEventListener("change", () => {
          updateQuantity(qtyInput.dataset.itemQty || "", Number(qtyInput.value));
          renderCart();
        });
      });
    };

    const activateTag = (tagName: string) => {
      tags.forEach((tagButton) => {
        const isActive = tagButton.dataset.tag === tagName;
        tagButton.dataset.active = isActive ? "true" : "false";
        tagButton.classList.toggle("border-primary", isActive);
        tagButton.classList.toggle("bg-primary", isActive);
        tagButton.classList.toggle("text-white", isActive);
        tagButton.classList.toggle("hover:text-white", isActive);
        tagButton.classList.toggle("hover:border-primary", isActive);
        tagButton.classList.toggle("border-border", !isActive);
        tagButton.classList.toggle("bg-light", !isActive);
        tagButton.classList.toggle("hover:text-primary", !isActive);
        tagButton.classList.toggle("hover:border-primary", !isActive);
      });

      cards.forEach((card: HTMLElement) => {
        const shouldShow = tagName === "Все" || card.dataset.category === tagName;
        card.style.display = shouldShow ? "" : "none";
      });
    };

    const sortCards = () => {
      const mode = sortSelect.value;
      const sorted = [...cards].sort((a, b) => {
        const labelPriorityA = Number(a.dataset.labelPriority || 2);
        const labelPriorityB = Number(b.dataset.labelPriority || 2);
        const priceA = Number(a.dataset.price || 0);
        const priceB = Number(b.dataset.price || 0);
        const titleA = (a.dataset.title || "").toLowerCase();
        const titleB = (b.dataset.title || "").toLowerCase();

        if (labelPriorityA !== labelPriorityB) return labelPriorityA - labelPriorityB;
        if (mode === "price-asc") return priceA - priceB;
        if (mode === "price-desc") return priceB - priceA;
        if (mode === "title-asc") return titleA.localeCompare(titleB, "ru");
        if (mode === "title-desc") return titleB.localeCompare(titleA, "ru");
        return titleA.localeCompare(titleB, "ru");
      });

      sorted.forEach((card: HTMLElement) => grid.appendChild(card));
      activateTag(activeTag);
    };

    tags.forEach((tagButton) => {
      tagButton.addEventListener("click", () => {
        activeTag = tagButton.dataset.tag || "Все";
        activateTag(activeTag);
      });
    });

    sortSelect.addEventListener("change", sortCards);

    addToCartButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.dataset.addToCart;
        if (!id) return;
        const title = button.dataset.title || "";
        const price = Number(button.dataset.price || 0);
        const qtyInput = document.querySelector(
          `[data-qty-input="${button.dataset.qtySource}"]`,
        ) as HTMLInputElement | null;
        const quantity = Math.max(1, Number(qtyInput?.value || 1));

        addToCart({ id, title, price, quantity });
        renderCart();
        document.dispatchEvent(new CustomEvent("cart:item-added"));
        // location.hash = "cart"; // User might still want to see the local cart update
      });
    });

    clearCartButton.addEventListener("click", () => {
      clearCart();
      renderCart();
    });

    renderCart();
    activateTag(activeTag);
  };

  const scheduleCatalogInit = () => {
    requestAnimationFrame(() => initCatalogPage());
  };

  scheduleCatalogInit();
  document.addEventListener("DOMContentLoaded", scheduleCatalogInit);
  document.addEventListener("astro:after-swap", scheduleCatalogInit);
  document.addEventListener("astro:page-load", scheduleCatalogInit);
  window.addEventListener("pageshow", scheduleCatalogInit);
</script>
