---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import { productCategories, products } from "@/data/products";

const tags = ["Все", ...productCategories];
---

<Base title="Каталог" description="Каталог товаров с ценами и фильтрами по категориям">
  <section class="section pb-6 pt-10">
    <div class="container text-center">
      <h1 class="mb-4">Каталог</h1>
      <p class="mx-auto max-w-2xl">
        Выберите категорию вверху, чтобы быстро отфильтровать товары.
      </p>
    </div>
  </section>

  <section class="section pb-6 pt-2">
    <div class="container">
      <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap gap-3" id="catalog-tags">
          {
            tags.map((tag, index) => (
              <button
                type="button"
                class={`rounded border px-4 py-2 text-sm transition ${
                  index === 0
                    ? "border-primary bg-primary text-white"
                    : "border-border bg-light hover:border-primary hover:text-primary dark:bg-darkmode-light"
                }`}
                data-tag={tag}
              >
                {tag}
              </button>
            ))
          }
        </div>
        <div class="flex items-center gap-2">
          <label for="catalog-sort" class="text-sm">Сортировка:</label>
          <select
            id="catalog-sort"
            class="rounded border border-border bg-light px-3 py-2 text-sm dark:bg-darkmode-light"
          >
            <option value="default">По умолчанию</option>
            <option value="price-asc">Цена: по возрастанию</option>
            <option value="price-desc">Цена: по убыванию</option>
            <option value="title-asc">Название: А-Я</option>
            <option value="title-desc">Название: Я-А</option>
          </select>
        </div>
      </div>

      <div class="row" id="catalog-grid">
        {
          products.map((product) => (
            <article
              class="mb-8 md:col-6 xl:col-3"
              data-category={product.category}
              data-price={product.price}
              data-title={product.title}
            >
              <div class="flex h-full flex-col rounded border border-border bg-light p-5 dark:border-darkmode-border dark:bg-darkmode-light">
                <ImageMod
                  class="mb-4 h-48 w-full rounded object-cover"
                  src={product.image}
                  alt={product.title}
                  width={380}
                  height={220}
                  format="webp"
                />
                <p class="mb-2 inline-block rounded bg-body px-3 py-1 text-xs dark:bg-darkmode-body">
                  {product.category}
                </p>
                <h4 class="mb-4 text-2xl leading-tight">{product.title}</h4>
                <p class="mb-4 text-2xl font-bold text-primary">{product.price} BYN</p>

                <div class="mt-auto grid grid-cols-[1fr_64px_1fr] items-center gap-2">
                  <button
                    type="button"
                    class="btn btn-buy btn-sm min-w-0 px-2 text-center"
                    data-add-to-cart={product.id}
                    data-price={product.price}
                    data-title={product.title}
                    data-qty-source={product.id}
                  >
                    Купить
                  </button>
                  <input
                    id={`qty-${product.id}`}
                    type="number"
                    min="1"
                    value="1"
                    class="w-16 rounded border border-border bg-body px-2 py-1 text-sm dark:border-darkmode-border dark:bg-darkmode-body"
                    data-qty-input={product.id}
                  />
                  <a
                    class="btn btn-outline-primary btn-sm min-w-0 px-2 text-center"
                    href={`/catalog/${product.id}`}
                  >
                    Подробнее
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section pt-2" id="cart">
    <div class="container">
      <div class="rounded border border-border bg-light p-5 dark:border-darkmode-border dark:bg-darkmode-light">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h3 class="mb-0">Корзина</h3>
          <span id="cart-count" class="rounded bg-body px-3 py-1 text-sm dark:bg-darkmode-body">
            0 товаров
          </span>
        </div>
        <div id="cart-items" class="mb-4"></div>
        <div class="mb-4 flex items-center justify-between border-t border-border pt-4 dark:border-darkmode-border">
          <strong>Итого:</strong>
          <strong id="cart-total">0 BYN</strong>
        </div>
        <div class="flex flex-wrap gap-3">
          <a class="btn btn-primary" href="/contact">Оформить заказ</a>
          <button id="clear-cart" type="button" class="btn btn-outline-primary">
            Очистить корзину
          </button>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const cartKey = "catalog-cart-v1";
  const tags = document.querySelectorAll("#catalog-tags [data-tag]");
  const grid = document.querySelector("#catalog-grid");
  const sortSelect = document.querySelector("#catalog-sort");
  const cards = Array.from(document.querySelectorAll("#catalog-grid [data-category]"));
  const addToCartButtons = document.querySelectorAll("[data-add-to-cart]");
  const cartItemsWrap = document.querySelector("#cart-items");
  const cartCount = document.querySelector("#cart-count");
  const cartTotal = document.querySelector("#cart-total");
  const clearCartButton = document.querySelector("#clear-cart");
  let activeTag = "Все";

  const formatPrice = (price) => `${price} BYN`;

  const getCart = () => {
    try {
      return JSON.parse(localStorage.getItem(cartKey) || "[]");
    } catch {
      return [];
    }
  };

  const saveCart = (cart) => {
    localStorage.setItem(cartKey, JSON.stringify(cart));
  };

  const renderCart = () => {
    const cart = getCart();
    const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
    const count = cart.reduce((sum, item) => sum + item.quantity, 0);
    cartCount.textContent = `${count} товаров`;
    cartTotal.textContent = formatPrice(total);

    if (!cart.length) {
      cartItemsWrap.innerHTML = '<p class="mb-0">Корзина пуста.</p>';
      return;
    }

    cartItemsWrap.innerHTML = cart
      .map(
        (item) => `
          <div class="mb-3 flex items-center justify-between gap-3 border-b border-border pb-3 dark:border-darkmode-border">
            <div>
              <p class="mb-1 font-semibold">${item.title}</p>
              <p class="mb-0 text-sm">${item.quantity} x ${formatPrice(item.price)}</p>
            </div>
            <div class="flex items-center gap-2">
              <button type="button" class="btn btn-outline-primary btn-sm" data-dec-item="${item.id}">-</button>
              <input
                type="number"
                min="1"
                value="${item.quantity}"
                class="w-16 rounded border border-border bg-body px-2 py-1 text-center text-sm dark:border-darkmode-border dark:bg-darkmode-body"
                data-item-qty="${item.id}"
              />
              <button type="button" class="btn btn-outline-primary btn-sm" data-inc-item="${item.id}">+</button>
              <button type="button" class="btn btn-outline-primary btn-sm" data-remove-item="${item.id}">Удалить</button>
            </div>
          </div>
        `,
      )
      .join("");

    const updateItemQuantity = (id, nextQty) => {
      const cart = getCart();
      const item = cart.find((entry) => entry.id === id);
      if (!item) return;
      item.quantity = Math.max(1, Number(nextQty) || 1);
      saveCart(cart);
      renderCart();
    };

    cartItemsWrap.querySelectorAll("[data-remove-item]").forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.dataset.removeItem;
        const nextCart = getCart().filter((item) => item.id !== id);
        saveCart(nextCart);
        renderCart();
      });
    });

    cartItemsWrap.querySelectorAll("[data-inc-item]").forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.dataset.incItem;
        const cart = getCart();
        const item = cart.find((entry) => entry.id === id);
        if (!item) return;
        item.quantity += 1;
        saveCart(cart);
        renderCart();
      });
    });

    cartItemsWrap.querySelectorAll("[data-dec-item]").forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.dataset.decItem;
        const cart = getCart();
        const item = cart.find((entry) => entry.id === id);
        if (!item) return;
        item.quantity = Math.max(1, item.quantity - 1);
        saveCart(cart);
        renderCart();
      });
    });

    cartItemsWrap.querySelectorAll("[data-item-qty]").forEach((input) => {
      input.addEventListener("change", () => {
        updateItemQuantity(input.dataset.itemQty, input.value);
      });
    });
  };

  const activateTag = (activeTag) => {
    tags.forEach((tagButton) => {
      const isActive = tagButton.dataset.tag === activeTag;
      tagButton.classList.toggle("border-primary", isActive);
      tagButton.classList.toggle("bg-primary", isActive);
      tagButton.classList.toggle("text-white", isActive);
      tagButton.classList.toggle("border-border", !isActive);
      tagButton.classList.toggle("bg-light", !isActive);
    });

    cards.forEach((card) => {
      const shouldShow =
        activeTag === "Все" || card.dataset.category === activeTag;
      card.style.display = shouldShow ? "" : "none";
    });
  };

  const sortCards = () => {
    const mode = sortSelect.value;
    const sorted = [...cards].sort((a, b) => {
      const priceA = Number(a.dataset.price || 0);
      const priceB = Number(b.dataset.price || 0);
      const titleA = (a.dataset.title || "").toLowerCase();
      const titleB = (b.dataset.title || "").toLowerCase();

      if (mode === "price-asc") return priceA - priceB;
      if (mode === "price-desc") return priceB - priceA;
      if (mode === "title-asc") return titleA.localeCompare(titleB, "ru");
      if (mode === "title-desc") return titleB.localeCompare(titleA, "ru");
      return 0;
    });

    sorted.forEach((card) => grid.appendChild(card));
    activateTag(activeTag);
  };

  tags.forEach((tagButton) => {
    tagButton.addEventListener("click", () => {
      activeTag = tagButton.dataset.tag || "Все";
      activateTag(activeTag);
    });
  });

  sortSelect.addEventListener("change", sortCards);

  addToCartButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const id = button.dataset.addToCart;
      const title = button.dataset.title || "";
      const price = Number(button.dataset.price || 0);
      const qtyInput = document.querySelector(
        `[data-qty-input="${button.dataset.qtySource}"]`,
      );
      const selectedQuantity = Math.max(1, Number(qtyInput?.value || 1));
      const cart = getCart();
      const existing = cart.find((item) => item.id === id);

      if (existing) {
        existing.quantity += selectedQuantity;
      } else {
        cart.push({ id, title, price, quantity: selectedQuantity });
      }

      saveCart(cart);
      renderCart();
      location.hash = "cart";
    });
  });

  clearCartButton.addEventListener("click", () => {
    saveCart([]);
    renderCart();
  });

  renderCart();
</script>
