---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { getNormalizedCollection } from "@/lib/contentCollections";
import {
  getStoreLabelPriority,
  normalizeStoreLabel,
} from "@/lib/utils/storeLabels";
import JsonLd from "@/components/JsonLd.astro";
const siteUrl = "https://teleofis24.by";

const homepageEntry = await getListPage("homepage", "-index");
const homepage = homepageEntry.data as any;

const catalogEntries = await getNormalizedCollection(
  "store",
  ({ data }) => !data.draft,
);

const topProducts = catalogEntries
  .map((entry) => {
    const priceNumber = Number(entry.data.price ?? 0);
    const label = normalizeStoreLabel(entry.data.custom_label_0);
    return {
      id: entry.id,
      title: entry.data.title,
      category: entry.data.category ?? "Без категории",
      price: Number.isNaN(priceNumber) ? 0 : priceNumber,
      image:
        entry.data.img || entry.data.image || "/images/image-placeholder.png",
      customLabel: label,
      labelPriority: getStoreLabelPriority(label),
    };
  })
  .sort((a, b) => a.labelPriority - b.labelPriority || b.price - a.price)
  .slice(0, 4);
---

<Base
  title={homepage.title}
  meta_title={homepage.meta_title}
  description={homepage.description}
  hideBreadcrumbs={true}
>
  <Fragment slot="head">
    <JsonLd
      type="FAQPage"
      data={{
        mainEntity: homepage.faq.items.map((item: any) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }}
    />

    <JsonLd
      type="LocalBusiness"
      data={{
        name: "ЧАСТНОЕ ПРЕДПРИЯТИЕ «ТЕЛЕОФИС»",
        image: `${siteUrl}/images/og-image.png`,
        "@id": `${siteUrl}/#organization`,
        url: siteUrl,
        telephone: "+375298462462",
        address: {
          "@type": "PostalAddress",
          streetAddress: "ул. Макаёнка, 12г, пом. 257",
          addressLocality: "Минск",
          postalCode: "220114",
          addressCountry: "BY",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: 53.921,
          longitude: 27.625,
        },
      }}
    />
  </Fragment>
  <!-- Hero -->
  <section class="section pb-16 pt-12">
    <div class="container">
      <div class="row items-center gap-y-10">
        <div class="md:col-6">
          <span class="hero-badge mb-5 inline-flex">{homepage.hero.badge}</span>
          <h1 class="mb-5 text-h4 leading-tight md:text-h3">
            {homepage.hero.title}
          </h1>
          <p class="mb-8 text-lg">{homepage.hero.subtitle}</p>
          <div class="mb-8 flex flex-col sm:flex-row flex-wrap gap-4">
            <a
              class="btn btn-primary w-full sm:w-auto text-center bg-linear-to-r from-primary to-blue-700 shadow-lg shadow-primary/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/40 active:scale-95"
              href={homepage.hero.primaryCta.link}
            >
              {homepage.hero.primaryCta.label}
            </a>
            <a
              class="btn btn-outline-primary w-full sm:w-auto text-center transition-all duration-300 hover:-translate-y-1 hover:bg-primary/5 hover:text-black dark:hover:text-black hover:shadow-lg active:scale-95"
              href={homepage.hero.secondaryCta.link}
            >
              {homepage.hero.secondaryCta.label}
            </a>
          </div>
          <ul
            class="grid grid-cols-1 gap-2 text-sm font-semibold sm:grid-cols-2"
          >
            {
              homepage.hero.trustItems.map((item: string) => (
                <li class="flex items-center gap-2">
                  <svg class="h-[1em] w-[1em] text-primary">
                    <use xlink:href="#icon-FaCheck" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="md:col-6 hidden md:block">
          <div class="hero-visual">
            <ImageMod
              src="/images/water_meter_blueprint.png"
              width={1200}
              height={1200}
              alt="Чертеж телеметрического счетчика воды"
              class="w-full max-w-[600px] h-auto object-cover mix-blend-multiply dark:mix-blend-screen mask-[radial-gradient(ellipse_at_center,black_50%,transparent_95%)]"
              format="webp"
              loading="eager"
              decoding="sync"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- /Hero -->

  <!-- Popular Products -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.popularProducts.title}
      </h2>
      <div class="row gap-y-6">
        {
          topProducts.map((product) => (
            <div class="sm:col-6 lg:col-3">
              <article
                class={`catalog-card relative flex h-full flex-col ${
                  product.customLabel === "premium"
                    ? "border-transparent bg-linear-to-br from-amber-200 via-amber-100 to-amber-300 p-px shadow-[0_18px_36px_rgba(217,119,6,0.16)] dark:from-amber-500/40 dark:via-amber-400/20 dark:to-amber-600/40"
                    : product.customLabel === "discount"
                      ? "border-emerald-300 shadow-[0_14px_28px_rgba(16,185,129,0.10)] dark:border-emerald-500/50"
                      : ""
                }`}
              >
                <div
                  class={`relative flex h-full flex-col ${
                    product.customLabel === "premium"
                      ? "rounded-[calc(1rem-1px)] bg-linear-to-b from-amber-50 via-body to-body p-5 dark:from-amber-500/10 dark:via-darkmode-light dark:to-darkmode-light"
                      : ""
                  }`}
                >
                  {product.customLabel === "premium" ? (
                    <div class="absolute right-4 top-4 z-10 inline-flex items-center gap-2 rounded-full border border-amber-300 bg-white/90 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-amber-800 shadow-sm backdrop-blur dark:border-amber-500/40 dark:bg-darkmode-light/90 dark:text-amber-200">
                      <svg class="h-[1em] w-[1em] text-amber-500 dark:text-amber-300">
                        <use xlink:href="#icon-FaCrown" />
                      </svg>
                      <span>TOP</span>
                    </div>
                  ) : product.customLabel === "discount" ? (
                    <div class="absolute right-4 top-4 z-10 inline-flex items-center gap-2 rounded-full border border-emerald-300 bg-white/90 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-emerald-800 shadow-sm backdrop-blur dark:border-emerald-500/40 dark:bg-darkmode-light/90 dark:text-emerald-200">
                      <svg class="h-[1em] w-[1em] text-emerald-500 dark:text-emerald-300">
                        <use xlink:href="#icon-FaShoppingBasket" />
                      </svg>
                      <span>SALE</span>
                    </div>
                  ) : null}
                  <ImageMod
                    src={product.image}
                    width={840}
                    height={480}
                    alt={product.title}
                    class="catalog-card-image"
                    format="webp"
                  />
                  <h3 class="card-title mt-4 min-h-12 text-text-dark dark:text-darkmode-text-dark">
                    {product.title}
                  </h3>
                  <p
                    class={`mt-3 min-h-8 flex items-center gap-2 text-lg font-semibold ${
                      product.customLabel === "premium"
                        ? "text-amber-700 dark:text-amber-300"
                        : product.customLabel === "discount"
                          ? "text-emerald-600 dark:text-emerald-300"
                          : "text-text-dark dark:text-darkmode-text-dark"
                    }`}
                  >
                    {product.customLabel === "premium" ? (
                      <svg class="h-[1em] w-[1em] text-amber-500 dark:text-amber-300">
                        <use xlink:href="#icon-FaCrown" />
                      </svg>
                    ) : null}
                    <span>{product.price} BYN</span>
                  </p>
                  <div class="mt-auto flex flex-col gap-2 pt-4 sm:flex-row">
                    <a
                      class="btn btn-primary w-full text-center py-2.5 text-base bg-linear-to-r from-emerald-500 to-emerald-600 border-emerald-500 text-white shadow-[0_10px_20px_rgba(16,185,129,0.18)] sm:w-auto sm:py-1.5 sm:text-sm hover:from-emerald-600 hover:to-emerald-700 hover:shadow-[0_12px_24px_rgba(16,185,129,0.24)]"
                      href={`/store/${product.id}/`}
                    >
                      Купить
                    </a>
                    <a
                      class="btn btn-outline-primary w-full text-center py-2.5 text-base sm:w-auto sm:py-1.5 sm:text-sm"
                      href={`/store/${product.id}/`}
                    >
                      Подробнее
                    </a>
                  </div>
                </div>
              </article>
            </div>
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <a
          class="btn btn-outline-primary"
          href={homepage.popularProducts.viewAll.link}
        >
          {homepage.popularProducts.viewAll.label}
        </a>
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="section-sm bg-gradient">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.solutions.title}
      </h2>
      <div class="row gap-y-6">
        {
          homepage.solutions.items.map((item: any) => (
            <div class="sm:col-6 lg:col-4">
              <article class="info-card h-full">
                <svg class="info-card-icon">
                  <use xlink:href={`#icon-${item.icon}`} />
                </svg>
                <h3 class="card-title mt-4 text-text-dark dark:text-darkmode-text-dark">
                  {item.title}
                </h3>
                <p class="mt-2">{item.text}</p>
                <a
                  class="mt-4 inline-block font-semibold hover:underline"
                  href={homepage.solutions.moreLink}
                >
                  {homepage.solutions.moreLabel}
                </a>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="section-sm">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.whyUs.title}
      </h2>
      <div class="row gap-y-6">
        {
          homepage.whyUs.items.map((item: any) => (
            <div class="sm:col-6 lg:col-4">
              <article class="trust-card h-full">
                <svg class="trust-card-icon">
                  <use xlink:href={`#icon-${item.icon}`} />
                </svg>
                <h3 class="card-title mt-4 text-text-dark dark:text-darkmode-text-dark">
                  {item.title}
                </h3>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How To Buy -->
  <section class="section-sm bg-gradient">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.howToBuy.title}
      </h2>
      <div class="row gap-y-6 items-stretch">
        <div class="lg:col-7">
          <div class="buy-timeline-panel h-full">
            <ol class="buy-timeline">
              {
                homepage.howToBuy.steps.map((step: any, idx: number) => (
                  <li class="buy-timeline-item">
                    <span class="buy-step-index">{idx + 1}</span>
                    <div>
                      <p class="buy-step-text">{step.title}</p>
                      <p class="buy-step-description">{step.description}</p>
                    </div>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
        <div class="lg:col-5">
          <aside class="buy-help-card">
            <div class="flex items-center gap-2">
              <svg class="buy-help-icon">
                <use xlink:href="#icon-FaCamera"></use>
              </svg>
              <h3
                class="text-lg font-semibold text-text-dark dark:text-darkmode-text-dark"
              >
                {homepage.howToBuy.helpCard.title}
              </h3>
            </div>
            <p class="mt-3 text-sm">{homepage.howToBuy.helpCard.text}</p>
            <form
              id="meter-photo-form"
              class="mt-4 space-y-3"
              enctype="multipart/form-data"
            >
              <label class="block">
                <span
                  class="mb-2 block text-sm font-semibold text-text-dark dark:text-darkmode-text-dark"
                >
                  Ваше имя
                </span>
                <input
                  class="block w-full rounded-md border border-border bg-white px-3 py-2 text-sm text-text-dark placeholder:text-text-light dark:border-darkmode-border dark:bg-darkmode-body dark:text-darkmode-text-dark"
                  id="meter-name"
                  name="name"
                  type="text"
                  placeholder="Иван"
                  required
                />
              </label>
              <label class="block">
                <span
                  class="mb-2 block text-sm font-semibold text-text-dark dark:text-darkmode-text-dark"
                >
                  Телефон
                </span>
                <input
                  class="block w-full rounded-md border border-border bg-white px-3 py-2 text-sm text-text-dark placeholder:text-text-light dark:border-darkmode-border dark:bg-darkmode-body dark:text-darkmode-text-dark"
                  id="meter-phone"
                  name="phone"
                  type="tel"
                  placeholder="+375XXXXXXXXX"
                  inputmode="tel"
                  autocomplete="tel"
                  required
                />
                <span
                  class="mt-1 block text-xs text-text-light dark:text-darkmode-text-light"
                >
                  Формат: +375XXXXXXXXX
                </span>
              </label>
              <label class="block">
                <span
                  class="mb-2 block text-sm font-semibold text-text-dark dark:text-darkmode-text-dark"
                >
                  Адрес установки
                </span>
                <input
                  class="block w-full rounded-md border border-border bg-white px-3 py-2 text-sm text-text-dark placeholder:text-text-light dark:border-darkmode-border dark:bg-darkmode-body dark:text-darkmode-text-dark"
                  id="meter-address"
                  name="address"
                  type="text"
                  placeholder="Минск, ул. ..."
                  required
                />
              </label>
              <label class="block">
                <span
                  class="mb-2 block text-sm font-semibold text-text-dark dark:text-darkmode-text-dark"
                >
                  Прикрепите фото
                </span>
                <input
                  class="block w-full cursor-pointer rounded-md border border-border bg-white px-3 py-2 text-sm text-text-dark file:mr-4 file:rounded-md file:border-0 file:bg-primary file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-primary/90 dark:border-darkmode-border dark:bg-darkmode-body dark:text-darkmode-text-dark"
                  id="meter-photo"
                  name="photo"
                  type="file"
                  accept="image/*"
                  data-max-size="5242880"
                  required
                />
                <span
                  class="mt-1 block text-xs text-text-light dark:text-darkmode-text-light"
                >
                  До 5 МБ
                </span>
              </label>
              <button class="btn btn-primary w-full text-center" type="submit">
                {homepage.howToBuy.helpCard.button.label}
              </button>
              <p
                id="meter-photo-status"
                class="text-sm text-text-light dark:text-darkmode-text-light"
              >
              </p>
            </form>
            <ul class="mt-4 space-y-2 text-sm">
              {
                homepage.howToBuy.helpCard.highlights.map((item: string) => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-1 h-[1em] w-[1em] text-primary">
                      <use xlink:href="#icon-FaCheck" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const form = document.getElementById("meter-photo-form");
      const status = document.getElementById("meter-photo-status");
      const photoInput = document.getElementById("meter-photo");
      const nameInput = document.getElementById("meter-name");
      const phoneInput = document.getElementById("meter-phone");
      const addressInput = document.getElementById("meter-address");
      const phoneError = document.createElement("p");

      if (
        !form ||
        !status ||
        !photoInput ||
        !nameInput ||
        !phoneInput ||
        !addressInput
      )
        return;
      phoneError.className = "mt-1 text-xs text-red-500";
      phoneError.setAttribute("aria-live", "polite");
      phoneInput.insertAdjacentElement("afterend", phoneError);

      const formatPhone = (value) => {
        const digits = value.replace(/\D/g, "");
        const normalized = digits.startsWith("375")
          ? digits.slice(3)
          : digits.startsWith("80")
            ? digits.slice(1)
            : digits;
        const phoneDigits = normalized.slice(0, 9);
        return phoneDigits ? `+375${phoneDigits}` : "+375";
      };

      phoneInput.addEventListener("input", () => {
        phoneInput.value = formatPhone(phoneInput.value);
        phoneError.textContent = "";
      });

      phoneInput.addEventListener("focus", () => {
        if (!phoneInput.value.trim()) {
          phoneInput.value = "+375";
        }
      });

      phoneInput.addEventListener("paste", () => {
        window.setTimeout(() => {
          phoneInput.value = formatPhone(phoneInput.value);
        }, 0);
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const file = photoInput.files && photoInput.files[0];

        if (!file) {
          status.textContent = "Выберите фото счётчика перед отправкой.";
          return;
        }

        const maxSize = Number(photoInput.dataset.maxSize || 5242880);
        if (file.size > maxSize) {
          status.textContent = "Размер фото не должен превышать 5 МБ.";
          return;
        }

        const normalizedPhone = formatPhone(phoneInput.value.trim());
        if (!/^\+375\d{9}$/.test(normalizedPhone)) {
          phoneError.textContent = "Введите номер в формате +375XXXXXXXXX";
          phoneInput.focus();
          return;
        }
        phoneInput.value = normalizedPhone;

        const formData = new FormData();
        formData.append("requestType", "meter_photo");
        formData.append("name", nameInput.value.trim());
        formData.append("phone", normalizedPhone);
        formData.append("address", addressInput.value.trim());
        formData.append("photo", file);

        status.textContent = "Отправка...";

        try {
          const response = await fetch("/api/send-callback.php", {
            method: "POST",
            body: formData,
          });

          const payload = await response.json();

          if (!response.ok || !payload.success) {
            throw new Error(payload.error || "Не удалось отправить фото");
          }

          form.reset();
          phoneError.textContent = "";
          status.textContent =
            "Фото отправлено. Мы свяжемся с вами после обработки.";
        } catch (error) {
          status.textContent =
            error instanceof Error ? error.message : "Ошибка отправки фото.";
        }
      });
    })();
  </script>

  <!-- Integrations -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.integrations.title}
      </h2>
      <div class="row gap-y-6">
        {
          homepage.integrations.items.map((item: any) => (
            <div class="sm:col-6 lg:col-3">
              <article class="integration-card h-full">
                <svg class="integration-card-icon">
                  <use xlink:href={`#icon-${item.icon}`} />
                </svg>
                <h3 class="mt-4 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {item.title}
                </h3>
                <p class="mt-2 text-sm">{item.text}</p>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- For Business -->
  <section class="section-sm" id="business">
    <div class="container">
      <div class="business-block">
        <h2 class="text-h3 text-white">{homepage.business.title}</h2>
        <p class="mt-4 max-w-3xl text-white/90">{homepage.business.text}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="btn btn-primary" href={homepage.business.primaryCta.link}>
            {homepage.business.primaryCta.label}
          </a>
          <a
            class="btn border-white text-white hover:bg-white hover:text-dark"
            href={homepage.business.secondaryCta.link}
          >
            {homepage.business.secondaryCta.label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Cases -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.cases.title}
      </h2>
      <div class="row gap-y-6">
        {
          homepage.cases.items.map((item: any) => (
            <div class="md:col-4">
              <article class="case-card h-full">
                <h3 class="card-title text-text-dark dark:text-darkmode-text-dark">
                  {item.object}
                </h3>
                <p class="mt-3 text-sm">
                  <strong>Проблема:</strong> {item.problem}
                </p>
                <p class="mt-3 text-sm">
                  <strong>Результат:</strong> {item.result}
                </p>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-sm">
    <div class="container">
      <div class="final-cta-block text-center">
        <h2 class="text-h3 text-text-dark dark:text-darkmode-text-dark">
          {homepage.finalCta.title}
        </h2>
        <p class="mt-3 text-lg">{homepage.finalCta.text}</p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a class="btn btn-primary" href={homepage.finalCta.primary.link}>
            {homepage.finalCta.primary.label}
          </a>
          <a
            class="btn btn-outline-primary"
            href={homepage.finalCta.secondary.link}
          >
            <svg class="mr-2 inline h-[1em] w-[1em]">
              <use xlink:href="#icon-FaPhoneAlt"></use>
            </svg>
            {homepage.finalCta.secondary.label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.faq.title}
      </h2>
      <div class="faq-list">
        {
          homepage.faq.items.map((item: any, idx: number) => (
            <details class="faq-item" open={idx === 0}>
              <summary class="faq-question">{item.question}</summary>
              <p class="faq-answer">{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</Base>
