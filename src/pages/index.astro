---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import {
  FaBroadcastTower,
  FaBuilding,
  FaCamera,
  FaCertificate,
  FaCheck,
  FaCogs,
  FaFire,
  FaHeadset,
  FaLayerGroup,
  FaMobileAlt,
  FaPhoneAlt,
  FaPlug,
  FaThermometerHalf,
  FaTint,
  FaTools,
  FaTruck,
  FaWater,
} from "react-icons/fa";

const popularProducts = [
  {
    title: "Teleofis RTU-101",
    specs: "GSM/NB-IoT модуль, 2 DI, 2 DO, RS-485",
    price: "от 590 BYN",
    image: "/images/service-1.png",
    buyLink: "/catalog",
    detailsLink: "/catalog",
  },
  {
    title: "VEGA Smart Flow",
    specs: "Дистанционный учёт воды, импульсные входы",
    price: "от 740 BYN",
    image: "/images/service-2.png",
    buyLink: "/catalog",
    detailsLink: "/catalog",
  },
  {
    title: "ТАХАТ Control Box",
    specs: "Контроль температуры и аварий, DIN-монтаж",
    price: "от 680 BYN",
    image: "/images/service-3.png",
    buyLink: "/catalog",
    detailsLink: "/catalog",
  },
  {
    title: "Router Gateway Pro",
    specs: "Промышленный роутер, VPN, удалённый доступ",
    price: "от 960 BYN",
    image: "/images/banner.png",
    buyLink: "/catalog",
    detailsLink: "/catalog",
  },
];

const solutions = [
  {
    title: "Удалённый учёт воды",
    text: "Сбор показаний, архив, аварийные уведомления.",
    icon: FaWater,
  },
  {
    title: "Дистанционный учет тепла",
    text: "Контроль теплопотребления с онлайн-дашбордом.",
    icon: FaFire,
  },
  {
    title: "GSM или NBIoT модули",
    text: "Подбор канала связи под объект и бюджет.",
    icon: FaBroadcastTower,
  },
  {
    title: "Контроль температуры",
    text: "Мониторинг и пороговые уведомления 24/7.",
    icon: FaThermometerHalf,
  },
  {
    title: "Автоматизация насосной станции",
    text: "Сценарии работы насосов и защита от аварий.",
    icon: FaCogs,
  },
  {
    title: "Телеметрия колодцев",
    text: "Уровень, протечки, доступ к данным онлайн.",
    icon: FaTint,
  },
];

const trustCards = [
  { title: "Оригинальное оборудование", icon: FaCertificate },
  { title: "Быстрая поставка", icon: FaTruck },
  { title: "Настройка под ключ", icon: FaTools },
  { title: "Техподдержка", icon: FaHeadset },
  { title: "Работа с юрлицами", icon: FaBuilding },
  { title: "Лицензионное программное обеспечение", icon: FaCheck },
];

const buySteps = [
  "Выберите оборудование",
  "Оплатите E-POS или запросите счёт по безналу",
  "Получите доставку / монтаж",
  "Поддержка после покупки",
];

const buyHighlights = [
  "Подбор совместимого оборудования под ваш счётчик и объект",
  "Коммерческое предложение в день обращения",
  "Удалённая помощь с первичным запуском",
];

const integrationCards = [
  {
    title: "Работаем с A1 и МТС",
    text: "Подбираем оптимальный канал передачи данных под объект и покрытие.",
    icon: FaMobileAlt,
  },
  {
    title: "Драйверы под любой протокол",
    text: "Разрабатываем драйверы и интеграции под нужный протокол обмена.",
    icon: FaPlug,
  },
  {
    title: 'Платформа EST.by \"Мой Клиент: Ресурсы\"',
    text: "Интеграция данных приборов учёта и телеметрии в едином интерфейсе.",
    icon: FaLayerGroup,
  },
  {
    title: "Платформа A1 от Nekta",
    text: "Подключаем и настраиваем решения для диспетчеризации и мониторинга.",
    icon: FaCogs,
  },
];

const cases = [
  {
    object: "Подвал",
    problem: "Протечки и отсутствие удалённого контроля.",
    result: "Автоматические уведомления и онлайн-мониторинг 24/7.",
  },
  {
    object: "Магазин",
    problem: "Риски порчи товара из-за температуры.",
    result: "Стабильный температурный контроль и снижение потерь.",
  },
  {
    object: "Квартира",
    problem: "Нет прозрачного учёта воды и тепла.",
    result: "Дистанционные показания и точная аналитика расходов.",
  },
];
---

<Base>
  <!-- Hero -->
  <section class="section pb-16 pt-12">
    <div class="container">
      <div class="row items-center gap-y-10">
        <div class="md:col-6">
          <span class="hero-badge mb-5 inline-flex">
            Официальные решения УП "Минскводоканала"
          </span>
          <h1 class="mb-5 text-h2 leading-tight md:text-h1">
            Оборудование Teleofis, Тахат, Вега и телеметрия в Беларуси
          </h1>
          <p class="mb-8 text-lg">
            Продажа оборудования, монтаж, удалённый мониторинг, обслуживание
            модулей и оплата онлайн через E-POS.
          </p>
          <div class="mb-8 flex flex-wrap gap-3">
            <a class="btn btn-primary" href="/catalog">Перейти в каталог</a>
            <a class="btn btn-outline-primary" href="/contact">
              Получить счёт для организации
            </a>
          </div>
          <ul class="grid grid-cols-1 gap-2 text-sm font-semibold sm:grid-cols-2">
            <li class="flex items-center gap-2">
              <FaCheck className="text-primary" />
              <span>Работаем по Беларуси</span>
            </li>
            <li class="flex items-center gap-2">
              <FaCheck className="text-primary" />
              <span>Гарантия</span>
            </li>
            <li class="flex items-center gap-2">
              <FaCheck className="text-primary" />
              <span>Оплата ЕРИП</span>
            </li>
            <li class="flex items-center gap-2">
              <FaCheck className="text-primary" />
              <span>Безналичный расчёт</span>
            </li>
          </ul>
        </div>
        <div class="md:col-6">
          <div class="hero-visual">
            <div class="hero-glow hero-glow-a"></div>
            <div class="hero-glow hero-glow-b"></div>
            <div class="hero-device-card hero-device-main">
              <div class="mb-4 flex items-center justify-between">
                <strong class="text-lg text-text-dark dark:text-darkmode-text-dark">
                  Telemetry Hub
                </strong>
                <span class="hero-dot"></span>
              </div>
              <div class="hero-bars mb-4">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
              </div>
              <p class="text-sm">Router status: online • 24 devices connected</p>
            </div>
            <div class="hero-device-card hero-device-top">
              <p class="mb-2 text-xs uppercase tracking-wide">3D Device Card</p>
              <div class="hero-device-image-wrap">
                <ImageMod
                  src="/images/service-1.png"
                  width={420}
                  height={220}
                  alt="Telemetry device"
                  class="hero-device-image"
                  format="webp"
                />
              </div>
              <p class="mt-3 text-sm">VEGA / Teleofis industrial telemetry</p>
            </div>
            <div class="hero-device-card hero-device-bottom">
              <p class="text-xs uppercase tracking-wide">Router Dashboard</p>
              <div class="hero-mini-card mt-3">
                <ImageMod
                  src="/images/service-2.png"
                  width={360}
                  height={160}
                  alt="Router dashboard"
                  class="hero-device-image"
                  format="webp"
                />
              </div>
              <div class="mt-3 grid grid-cols-2 gap-2">
                <div class="hero-stat">
                  <strong>99.8%</strong>
                  <span>Uptime</span>
                </div>
                <div class="hero-stat">
                  <strong>12</strong>
                  <span>Nodes</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- /Hero -->

  <!-- Popular Products -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        Популярные товары
      </h2>
      <div class="row gap-y-6">
        {
          popularProducts.map((product) => (
            <div class="sm:col-6 lg:col-3">
              <article class="catalog-card h-full">
                <ImageMod
                  src={product.image}
                  width={420}
                  height={240}
                  alt={product.title}
                  class="catalog-card-image"
                  format="webp"
                />
                <h3 class="mt-4 text-xl font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {product.title}
                </h3>
                <p class="mt-2 text-sm">{product.specs}</p>
                <p class="mt-3 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {product.price}
                </p>
                <div class="mt-4 flex gap-2">
                  <a class="btn btn-primary btn-sm" href={product.buyLink}>Купить</a>
                  <a class="btn btn-outline-primary btn-sm" href={product.detailsLink}>
                    Подробнее
                  </a>
                </div>
              </article>
            </div>
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <a class="btn btn-outline-primary" href="/catalog">View all products</a>
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="section-sm bg-gradient">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        Готовые решения под задачи
      </h2>
      <div class="row gap-y-6">
        {
          solutions.map((item) => (
            <div class="sm:col-6 lg:col-4">
              <article class="info-card h-full">
                <item.icon className="info-card-icon" />
                <h3 class="mt-4 text-xl font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {item.title}
                </h3>
                <p class="mt-2">{item.text}</p>
                <a class="mt-4 inline-block font-semibold hover:underline" href="/solutions">
                  Подробнее
                </a>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="section-sm">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        Почему выбирают teleofis24.by
      </h2>
      <div class="row gap-y-6">
        {
          trustCards.map((item) => (
            <div class="sm:col-6 lg:col-4">
              <article class="trust-card h-full">
                <item.icon className="trust-card-icon" />
                <h3 class="mt-4 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {item.title}
                </h3>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How To Buy -->
  <section class="section-sm bg-gradient">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        Как купить
      </h2>
      <div class="row gap-y-6">
        <div class="lg:col-8">
          <ol class="buy-timeline">
            {
              buySteps.map((step, idx) => (
                <li class="buy-timeline-item">
                  <span class="buy-step-index">{idx + 1}</span>
                  <p class="buy-step-text">{step}</p>
                </li>
              ))
            }
          </ol>
        </div>
        <div class="lg:col-4">
          <aside class="buy-help-card">
            <div class="flex items-center gap-2">
              <FaCamera className="buy-help-icon" />
              <h3 class="text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
                Скиньте фото счётчика
              </h3>
            </div>
            <p class="mt-3 text-sm">
              Отправьте фото вашего счётчика или узла учёта в Telegram и мы
              подготовим точное предложение под ваш объект.
            </p>
            <a
              class="btn btn-primary mt-4 w-full text-center"
              href="https://t.me/teleofis24"
              target="_blank"
              rel="noopener"
            >
              Отправить фото в Telegram
            </a>
            <ul class="mt-4 space-y-2 text-sm">
              {
                buyHighlights.map((item) => (
                  <li class="flex items-start gap-2">
                    <FaCheck className="mt-1 text-primary" />
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        Интеграции и протоколы
      </h2>
      <div class="row gap-y-6">
        {
          integrationCards.map((item) => (
            <div class="sm:col-6 lg:col-3">
              <article class="integration-card h-full">
                <item.icon className="integration-card-icon" />
                <h3 class="mt-4 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {item.title}
                </h3>
                <p class="mt-2 text-sm">{item.text}</p>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- For Business -->
  <section class="section-sm">
    <div class="container">
      <div class="business-block">
        <h2 class="text-h3 text-white">Работаем с организациями</h2>
        <p class="mt-4 max-w-3xl text-white/90">
          Счета, договоры, безналичный расчёт, поставки, сервисное обслуживание,
          индивидуальные решения.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="btn btn-primary" href="/contact">Получить счёт</a>
          <a class="btn border-white text-white hover:bg-white hover:text-dark" href="/contact">
            Связаться с менеджером
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Cases -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        Кейсы / отзывы
      </h2>
      <div class="row gap-y-6">
        {
          cases.map((item) => (
            <div class="md:col-4">
              <article class="case-card h-full">
                <h3 class="text-xl font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {item.object}
                </h3>
                <p class="mt-3 text-sm"><strong>Проблема:</strong> {item.problem}</p>
                <p class="mt-3 text-sm"><strong>Результат:</strong> {item.result}</p>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-sm">
    <div class="container">
      <div class="final-cta-block text-center">
        <h2 class="text-h3 text-text-dark dark:text-darkmode-text-dark">
          Не знаете что выбрать?
        </h2>
        <p class="mt-3 text-lg">Подберём решение под ваш объект за 15 минут.</p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a class="btn btn-primary" href="/contact">Консультация</a>
          <a class="btn btn-outline-primary" href="tel:+375293652910">
            <FaPhoneAlt className="mr-2 inline" /> Позвонить
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
