---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import {
  FaBroadcastTower,
  FaBuilding,
  FaCamera,
  FaCertificate,
  FaCheck,
  FaCogs,
  FaFire,
  FaHeadset,
  FaLayerGroup,
  FaMobileAlt,
  FaPhoneAlt,
  FaPlug,
  FaThermometerHalf,
  FaTint,
  FaTools,
  FaTruck,
  FaWater,
} from "react-icons/fa";

const homepageEntry = await getListPage("homepage", "-index");
const homepage = homepageEntry.data as any;

const iconMap = {
  FaWater,
  FaFire,
  FaBroadcastTower,
  FaThermometerHalf,
  FaCogs,
  FaTint,
  FaCertificate,
  FaTruck,
  FaTools,
  FaHeadset,
  FaBuilding,
  FaCheck,
  FaMobileAlt,
  FaPlug,
  FaLayerGroup,
} as const;
---

<Base>
  <!-- Hero -->
  <section class="section pb-16 pt-12">
    <div class="container">
      <div class="row items-center gap-y-10">
        <div class="md:col-6">
          <span class="hero-badge mb-5 inline-flex">{homepage.hero.badge}</span>
          <h1 class="mb-5 text-h4 leading-tight md:text-h3">{homepage.hero.title}</h1>
          <p class="mb-8 text-lg">{homepage.hero.subtitle}</p>
          <div class="mb-8 flex flex-col sm:flex-row flex-wrap gap-4">
            <a class="btn btn-primary w-full sm:w-auto text-center bg-gradient-to-r from-primary to-blue-500 shadow-lg shadow-primary/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/40 active:scale-95" href={homepage.hero.primaryCta.link}>
              {homepage.hero.primaryCta.label}
            </a>
            <a class="btn btn-outline-primary w-full sm:w-auto text-center transition-all duration-300 hover:-translate-y-1 hover:bg-primary/5 hover:text-black dark:hover:text-black hover:shadow-lg active:scale-95" href={homepage.hero.secondaryCta.link}>
              {homepage.hero.secondaryCta.label}
            </a>
          </div>
          <ul class="grid grid-cols-1 gap-2 text-sm font-semibold sm:grid-cols-2">
            {
              homepage.hero.trustItems.map((item: string) => (
                <li class="flex items-center gap-2">
                  <FaCheck className="text-primary" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="md:col-6">
          <div class="hero-visual p-4 sm:p-5 flex items-center justify-center">
            <div class="hero-glow hero-glow-a"></div>
            <div class="hero-glow hero-glow-b"></div>
            
            <div class="hero-device-single justify-between max-h-[500px]">
              <div class="mb-4 flex items-center justify-between border-b border-border/50 pb-3 dark:border-darkmode-border/50">
                <div class="flex items-center gap-2.5">
                  <span class="rounded bg-primary/10 p-1.5 text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">
                    <FaBroadcastTower className="text-xl" />
                  </span>
                  <strong class="text-sm md:text-base uppercase tracking-widest text-text-dark dark:text-darkmode-text-dark font-secondary">
                    NBIoT Система
                  </strong>
                </div>
                <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-green-500 bg-green-500/10 px-2 py-1 rounded-full">
                  <span class="hero-dot"></span> Мониторинг
                </div>
              </div>
              
              <div class="relative mt-2 flex flex-1 overflow-hidden rounded-xl bg-white border border-border/40 dark:border-darkmode-border/40 dark:bg-darkmode-body">
                <ImageMod
                  src="/images/water_meter_blueprint.png"
                  width={400}
                  height={400}
                  alt="Чертеж телеметрического счетчика воды"
                  class="w-full h-full object-cover mix-blend-multiply dark:mix-blend-screen"
                  format="webp"
                />
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- /Hero -->

  <!-- Popular Products -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.popularProducts.title}
      </h2>
      <div class="row gap-y-6">
        {
          homepage.popularProducts.items.map((product: any) => (
            <div class="sm:col-6 lg:col-3">
              <article class="catalog-card flex h-full flex-col">
                <ImageMod
                  src={product.image}
                  width={420}
                  height={240}
                  alt={product.title}
                  class="catalog-card-image"
                  format="webp"
                />
                <h3 class="mt-4 text-xl font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {product.title}
                </h3>
                <p class="mt-2 text-sm">{product.specs}</p>
                <p class="mt-3 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {product.price}
                </p>
                <div class="mt-auto pt-4 flex flex-col sm:flex-row gap-2">
                  <a class="btn btn-primary w-full sm:w-auto text-center py-2.5 text-base sm:py-1.5 sm:text-sm" href={product.buy.link}>
                    {product.buy.label}
                  </a>
                  <a class="btn btn-outline-primary w-full sm:w-auto text-center py-2.5 text-base sm:py-1.5 sm:text-sm" href={product.details.link}>
                    {product.details.label}
                  </a>
                </div>
              </article>
            </div>
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <a class="btn btn-outline-primary" href={homepage.popularProducts.viewAll.link}>
          {homepage.popularProducts.viewAll.label}
        </a>
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="section-sm bg-gradient">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.solutions.title}
      </h2>
      <div class="row gap-y-6">
        {
          homepage.solutions.items.map((item: any) => {
            const Icon = iconMap[item.icon as keyof typeof iconMap] || FaCogs;
            return (
              <div class="sm:col-6 lg:col-4">
                <article class="info-card h-full">
                  <Icon className="info-card-icon" />
                  <h3 class="mt-4 text-xl font-semibold text-text-dark dark:text-darkmode-text-dark">
                    {item.title}
                  </h3>
                  <p class="mt-2">{item.text}</p>
                  <a
                    class="mt-4 inline-block font-semibold hover:underline"
                    href={homepage.solutions.moreLink}
                  >
                    {homepage.solutions.moreLabel}
                  </a>
                </article>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="section-sm">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.whyUs.title}
      </h2>
      <div class="row gap-y-6">
        {
          homepage.whyUs.items.map((item: any) => {
            const Icon = iconMap[item.icon as keyof typeof iconMap] || FaCheck;
            return (
              <div class="sm:col-6 lg:col-4">
                <article class="trust-card h-full">
                  <Icon className="trust-card-icon" />
                  <h3 class="mt-4 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
                    {item.title}
                  </h3>
                </article>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- How To Buy -->
  <section class="section-sm bg-gradient">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.howToBuy.title}
      </h2>
      <div class="row gap-y-6 items-stretch">
        <div class="lg:col-7">
          <div class="buy-timeline-panel h-full">
            <ol class="buy-timeline">
              {
                homepage.howToBuy.steps.map((step: any, idx: number) => (
                  <li class="buy-timeline-item">
                    <span class="buy-step-index">{idx + 1}</span>
                    <div>
                      <p class="buy-step-text">{step.title}</p>
                      <p class="buy-step-description">{step.description}</p>
                    </div>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
        <div class="lg:col-5">
          <aside class="buy-help-card">
            <div class="flex items-center gap-2">
              <FaCamera className="buy-help-icon" />
              <h3 class="text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
                {homepage.howToBuy.helpCard.title}
              </h3>
            </div>
            <p class="mt-3 text-sm">{homepage.howToBuy.helpCard.text}</p>
            <a
              class="btn btn-primary mt-4 w-full text-center"
              href={homepage.howToBuy.helpCard.button.link}
              target="_blank"
              rel="noopener"
            >
              {homepage.howToBuy.helpCard.button.label}
            </a>
            <ul class="mt-4 space-y-2 text-sm">
              {
                homepage.howToBuy.helpCard.highlights.map((item: string) => (
                  <li class="flex items-start gap-2">
                    <FaCheck className="mt-1 text-primary" />
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.integrations.title}
      </h2>
      <div class="row gap-y-6">
        {
          homepage.integrations.items.map((item: any) => {
            const Icon = iconMap[item.icon as keyof typeof iconMap] || FaCogs;
            return (
              <div class="sm:col-6 lg:col-3">
                <article class="integration-card h-full">
                  <Icon className="integration-card-icon" />
                  <h3 class="mt-4 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
                    {item.title}
                  </h3>
                  <p class="mt-2 text-sm">{item.text}</p>
                </article>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- For Business -->
  <section class="section-sm">
    <div class="container">
      <div class="business-block">
        <h2 class="text-h3 text-white">{homepage.business.title}</h2>
        <p class="mt-4 max-w-3xl text-white/90">{homepage.business.text}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="btn btn-primary" href={homepage.business.primaryCta.link}>
            {homepage.business.primaryCta.label}
          </a>
          <a
            class="btn border-white text-white hover:bg-white hover:text-dark"
            href={homepage.business.secondaryCta.link}
          >
            {homepage.business.secondaryCta.label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Cases -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.cases.title}
      </h2>
      <div class="row gap-y-6">
        {
          homepage.cases.items.map((item: any) => (
            <div class="md:col-4">
              <article class="case-card h-full">
                <h3 class="text-xl font-semibold text-text-dark dark:text-darkmode-text-dark">
                  {item.object}
                </h3>
                <p class="mt-3 text-sm"><strong>Проблема:</strong> {item.problem}</p>
                <p class="mt-3 text-sm"><strong>Результат:</strong> {item.result}</p>
              </article>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section-sm">
    <div class="container">
      <div class="final-cta-block text-center">
        <h2 class="text-h3 text-text-dark dark:text-darkmode-text-dark">
          {homepage.finalCta.title}
        </h2>
        <p class="mt-3 text-lg">{homepage.finalCta.text}</p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a class="btn btn-primary" href={homepage.finalCta.primary.link}>
            {homepage.finalCta.primary.label}
          </a>
          <a class="btn btn-outline-primary" href={homepage.finalCta.secondary.link}>
            <FaPhoneAlt className="mr-2 inline" /> {homepage.finalCta.secondary.label}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-sm pt-0">
    <div class="container">
      <h2 class="mb-8 text-h3 text-text-dark dark:text-darkmode-text-dark">
        {homepage.faq.title}
      </h2>
      <div class="faq-list">
        {
          homepage.faq.items.map((item: any, idx: number) => (
            <details class="faq-item" open={idx === 0}>
              <summary class="faq-question">{item.question}</summary>
              <p class="faq-answer">{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</Base>
