---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
import { getCollection, render } from "astro:content";

const infoEntries = await getCollection("info", ({ data }) => !data.draft);
const items = await Promise.all(
  infoEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
---

<Base
  title="Доставка и оплата"
  meta_title="Доставка и оплата"
  description="Информация о доставке и оплате"
>
  <PageHeader title="Доставка и оплата" />

  <section class="section-sm">
    <div class="container">
      {
        items.length ? (
          <div class="row" id="delivery-payment-grid">
            {items.map(({ entry, Content }, index) => (
              <div class="mb-8 md:col-6 xl:col-4">
                <article class="flex h-full flex-col rounded-lg border border-border bg-light p-6 dark:bg-darkmode-light">
                  <div class="flex-1">
                    {
                      entry.data.img && (
                        <ImageMod
                          class="mb-6 rounded"
                          src={entry.data.img}
                          width={1200}
                          height={600}
                          alt={entry.data.title}
                          format="webp"
                        />
                      )
                    }
                    <h2 class="h3 mb-3">{entry.data.title}</h2>
                    {
                      entry.data.description && (
                        <p class="mb-5 text-text-dark dark:text-darkmode-text">
                          {entry.data.description}
                        </p>
                      )
                    }
                  </div>

                  <button
                    type="button"
                    class="btn btn-outline-primary btn-sm self-start"
                    data-details-toggle={`delivery-payment-content-${index}`}
                    aria-expanded="false"
                  >
                    Подробнее
                  </button>

                  <div
                    id={`delivery-payment-content-${index}`}
                    class="content mt-5 hidden"
                  >
                    <Content />
                  </div>
                </article>
              </div>
            ))}
          </div>
        ) : (
          <p>Информация пока не добавлена.</p>
        )
      }
    </div>
  </section>
</Base>

<script>
  const initDeliveryPaymentCards = () => {
    const buttons = document.querySelectorAll(
      "#delivery-payment-grid [data-details-toggle]",
    ) as NodeListOf<HTMLButtonElement>;

    buttons.forEach((button) => {
      if (button.dataset.bound === "true") return;

      button.dataset.bound = "true";
      button.addEventListener("click", () => {
        const targetId = button.dataset.detailsToggle;
        if (!targetId) return;

        const content = document.getElementById(targetId);
        if (!content) return;

        const isHidden = content.classList.contains("hidden");
        content.classList.toggle("hidden", !isHidden);
        button.setAttribute("aria-expanded", String(isHidden));
        button.textContent = isHidden ? "Скрыть" : "Подробнее";
      });
    });
  };

  document.addEventListener("astro:page-load", initDeliveryPaymentCards);
  initDeliveryPaymentCards();
</script>
