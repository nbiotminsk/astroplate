---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import { getNormalizedCollection } from "@/lib/contentCollections";
import PageHeader from "@/partials/PageHeader.astro";

const infoEntries = await getNormalizedCollection("info", ({ data }) => !data.draft);
---

<Base
  title="Доставка и оплата"
  meta_title="Доставка и оплата"
  description="Информация о доставке и оплате"
>
  <PageHeader title="Доставка и оплата" compact={true} />

  <section class="py-8 xl:py-10">
    <div class="container">
      {
        infoEntries.length ? (
          <div class="row">
            {infoEntries.map((entry) => (
              <div class="mb-8 md:col-6 xl:col-4">
                <article class="flex h-full flex-col rounded-lg border border-border bg-light p-6 dark:bg-darkmode-light">
                  <div class="flex-1">
                    {
                      entry.data.img && (
                        <ImageMod
                          class="mb-6 rounded"
                          src={entry.data.img}
                          width={1200}
                          height={600}
                          alt={entry.data.title}
                          format="webp"
                        />
                      )
                    }
                    <h2 class="card-title mb-3 text-text-dark dark:text-darkmode-text-dark">{entry.data.title}</h2>
                    {
                      entry.data.description && (
                        <p class="mb-5 text-text-dark dark:text-darkmode-text">
                          {entry.data.description}
                        </p>
                      )
                    }
                  </div>

                  <a
                    href={`/info/${entry.id}`}
                    class="btn btn-outline-primary btn-sm self-start"
                  >
                    Подробнее
                  </a>
                </article>
              </div>
            ))}
          </div>
        ) : (
          <p>Информация пока не добавлена.</p>
        )
      }
    </div>
  </section>
</Base>
