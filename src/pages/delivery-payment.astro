---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
import { getCollection, render } from "astro:content";

const infoEntries = await getCollection("info", ({ data }) => !data.draft);
const items = await Promise.all(
  infoEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
---

<Base
  title="Доставка и оплата"
  meta_title="Доставка и оплата"
  description="Информация о доставке и оплате"
>
  <PageHeader title="Доставка и оплата" />

  <section class="section-sm">
    <div class="container">
      {
        items.length ? (
          <div class="row justify-center">
            <div class="lg:col-10">
              <div class="space-y-12">
                {items.map(({ entry, Content }) => (
                  <article class="rounded-lg border border-border bg-light p-6 dark:bg-darkmode-light">
                    {
                      entry.data.img && (
                        <ImageMod
                          class="mb-6 rounded"
                          src={entry.data.img}
                          width={1200}
                          height={600}
                          alt={entry.data.title}
                          format="webp"
                        />
                      )
                    }
                    <h2 class="h3 mb-3">{entry.data.title}</h2>
                    {
                      entry.data.description && (
                        <p class="mb-4 text-text-dark dark:text-darkmode-text">
                          {entry.data.description}
                        </p>
                      )
                    }
                    <div class="content">
                      <Content />
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <p>Информация пока не добавлена.</p>
        )
      }
    </div>
  </section>
</Base>
