---
import { humanize } from "@/lib/utils/textConverter";

const { className, title }: { className?: string; title?: string } = Astro.props;

const labelMap: Record<string, string> = {
  blog: "Блог",
  tags: "Теги",
  categories: "Категории",
  solutions: "Решения",
  services: "Услуги",
  contact: "Контакты",
  store: "Магазин",
  info: "Информация",
  "delivery-payment": "Доставка и оплата",
};

const paths = Astro.url.pathname.split("/").filter((x) => x);
let parts = [
  {
    label: "Главная",
    href: "/",
    "aria-label": Astro.url.pathname === "/" ? "page" : undefined,
  },
];

paths.forEach((label: string, i: number) => {
  const href = `/${paths.slice(0, i + 1).join("/")}`;
  const normalizedLabel = label.replace(".html", "").replace(/[-_]/g, " ");
  const translatedLabel =
    i === paths.length - 1 && title
      ? title
      : labelMap[label] || humanize(normalizedLabel) || "";
  label !== "page" &&
    parts.push({
      label: translatedLabel,
      href,
      "aria-label": Astro.url.pathname === href ? "page" : undefined,
    });
});
---

<nav aria-label="Breadcrumb" class={className}>
  <ol class="inline-flex flex-wrap items-center text-sm md:text-base" role="list">
    {
      parts.map(({ label, ...attrs }, index) => (
        <li class="mx-1 flex items-center capitalize" role="listitem">
          {index > 0 && <span class="inline-block mr-1">/</span>}
          {index !== parts.length - 1 ? (
            <a class="inline-flex items-center px-1 min-h-[44px] text-primary dark:text-darkmode-primary" {...attrs}>
              {label}
            </a>
          ) : (
            <span class="inline-flex items-center px-1 min-h-[44px] text-text-light dark:text-darkmode-text-light">
              {label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
