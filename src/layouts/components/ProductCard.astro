---
import ImageMod from "./ImageMod.astro";

const { product } = Astro.props;
const { id, title, price, image, availability, customLabel } = product;
---

<div
  class={`catalog-card group relative flex h-full flex-col rounded-2xl border bg-body p-4 shadow-sm transition hover:-translate-y-1 hover:shadow-lg dark:bg-darkmode-light ${
    customLabel === "premium"
      ? "border-amber-300 dark:border-amber-500/50"
      : customLabel === "discount"
        ? "border-emerald-300 dark:border-emerald-500/50"
        : "border-border dark:border-darkmode-border"
  }`}
>
  {
    customLabel === "premium" ? (
      <div class="absolute right-4 top-4 z-10 inline-flex items-center gap-2 rounded-full border border-amber-300 bg-white/90 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-amber-800 shadow-sm backdrop-blur dark:border-amber-500/40 dark:bg-darkmode-light/90 dark:text-amber-200">
        <svg class="h-[1em] w-[1em] text-amber-500 dark:text-amber-300">
          <use xlink:href="#icon-FaCrown" />
        </svg>
        <span>TOP</span>
      </div>
    ) : customLabel === "discount" ? (
      <div class="absolute right-4 top-4 z-10 inline-flex items-center gap-2 rounded-full border border-emerald-300 bg-white/90 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-emerald-800 shadow-sm backdrop-blur dark:border-emerald-500/40 dark:bg-darkmode-light/90 dark:text-emerald-200">
        <svg class="h-[1em] w-[1em] text-emerald-500 dark:text-emerald-300">
          <use xlink:href="#icon-FaShoppingBasket" />
        </svg>
        <span>SALE</span>
      </div>
    ) : null
  }
  <a href={`/store/${id}`} aria-label={`Открыть ${title}`}>
    <div
      class="catalog-card__image mb-4 flex h-48 items-center justify-center overflow-hidden rounded-xl border border-border bg-light dark:border-darkmode-border dark:bg-darkmode-body"
    >
      <ImageMod
        class="h-full w-full object-contain"
        src={image}
        alt={title}
        width={760}
        height={440}
        format="webp"
        loading="lazy"
      />
    </div>
  </a>
  <h4
    class="card-title mb-4 min-h-10 text-text-dark dark:text-darkmode-text-dark text-lg"
  >
    {title}
  </h4>
  <div class="mt-auto flex flex-col gap-2 pt-4">
    <div class="flex flex-col gap-1">
      <p
        class={`min-h-8 text-lg font-semibold leading-none ${
          customLabel === "premium"
            ? "text-amber-700 dark:text-amber-300"
            : customLabel === "discount"
              ? "text-emerald-600 dark:text-emerald-300"
              : "text-emerald-600"
        }`}
      >
        {price} BYN
      </p>
      <p
        class={`min-h-6 text-sm leading-none ${
          availability ? "text-green-700" : "text-red-700"
        }`}
      >
        {availability ? "В наличии" : "Нет в наличии"}
      </p>
    </div>

    <div
      class="flex flex-col gap-2 pt-2 sm:grid sm:grid-cols-[1fr_64px_1fr] sm:items-center sm:pt-0"
    >
      <button
        type="button"
        class={`btn btn-primary w-full text-center py-2.5 text-base bg-linear-to-r from-emerald-500 to-emerald-600 border-emerald-500 text-white shadow-[0_10px_20px_rgba(16,185,129,0.18)] transition-all duration-300 hover:-translate-y-1 hover:from-emerald-600 hover:to-emerald-700 hover:shadow-[0_12px_24px_rgba(16,185,129,0.24)] active:scale-95 sm:btn-sm sm:min-w-0 sm:px-2 sm:py-1 sm:text-sm ${
          !availability ? "cursor-not-allowed opacity-50" : ""
        }`}
        data-add-to-cart={id}
        data-price={price}
        data-title={title}
        data-qty-source={id}
        disabled={!availability}
      >
        Купить
      </button>
      <input
        id={`qty-${id}`}
        type="number"
        min="1"
        value="1"
        class="hidden w-full rounded border border-border bg-body px-2 py-1 text-sm dark:border-darkmode-border dark:bg-darkmode-body sm:block text-center"
        data-qty-input={id}
      />
      <a
        class="btn btn-outline-primary w-full text-center py-2.5 text-base text-emerald-600/70 sm:btn-sm sm:min-w-0 sm:border-transparent sm:bg-transparent sm:px-2 sm:py-1 sm:text-sm sm:hover:text-emerald-600 sm:hover:underline"
        href={`/store/${id}`}
      >
        Подробнее
      </a>
    </div>
  </div>
</div>

<style>
  .catalog-card {
    transform: translateY(0);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    transition:
      transform 0.24s ease,
      box-shadow 0.24s ease,
      border-color 0.24s ease;
  }

  .catalog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 38px rgba(15, 23, 42, 0.12);
  }

  .catalog-card__image {
    transition:
      transform 0.3s ease,
      filter 0.3s ease;
  }

  .catalog-card:hover .catalog-card__image {
    transform: scale(1.02);
    filter: saturate(1.05);
  }

  @media (prefers-reduced-motion: reduce) {
    .catalog-card,
    .catalog-card__image {
      transition: none;
    }

    .catalog-card:hover {
      transform: none;
    }

    .catalog-card:hover .catalog-card__image {
      transform: none;
      filter: none;
    }
  }
</style>
