---
import BlogCard from "@/components/BlogCard.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Share from "@/components/Share.astro";
import Disqus from "@/helpers/Disqus";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import similarItems from "@/lib/utils/similarItems";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { render } from "astro:content";
import { FaRegClock, FaRegFolder, FaRegUserCircle } from "react-icons/fa";
import ImageMod from "./components/ImageMod.astro";
import ProductCard from "./components/ProductCard.astro";
import { getNormalizedCollection } from "@/lib/contentCollections";
import { normalizeStoreLabel } from "@/lib/utils/storeLabels";
import config from "@/config/config.json";

const COLLECTION_FOLDER = "blog";
const { post } = Astro.props;

const siteUrl = config.site.base_url.replace(/\/$/, "");
const postUrl = `${siteUrl}/${post.id}`;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "image": post.data.image ? [{
    "@type": "ImageObject",
    "url": `${siteUrl}${post.data.image}`,
    "caption": post.data.alt_img || post.data.title,
    "description": post.data.alt_img || post.data.title
  }] : [],
  "datePublished": post.data.date,
  "author": {
    "@type": "Person",
    "name": post.data.author
  },
  "publisher": {
    "@type": "Organization",
    "name": config.site.title,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}${config.site.logo || "/images/favicon.png"}`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl
  }
};

const posts = await getSinglePage(COLLECTION_FOLDER);
const similarPosts = similarItems(post, posts);
const { Content } = await render(post);
const { title, description, author, categories, image, date, tags, alt_img } = post.data;

const catalogEntries = await getNormalizedCollection(
  "store",
  ({ data }) => !data.draft && data.category !== "услуги",
);

const recommendedProducts = catalogEntries
  .map((entry) => {
    const priceNumber = Number(entry.data.price ?? 0);
    const label = normalizeStoreLabel(entry.data.custom_label_0);

    return {
      id: entry.id,
      title: entry.data.title,
      category: entry.data.category ?? "others",
      price: Number.isNaN(priceNumber) ? 0 : priceNumber,
      image: entry.data.img || entry.data.image || "/images/image-placeholder.png",
      availability: entry.data.availability !== false,
      customLabel: label,
    };
  })
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />

<section class="section pt-7">
  <div class="container">
    <div class="row justify-center">
      <article class="lg:col-10">
        <Breadcrumbs className="mb-6" title={title} />
        <h1 set:html={markdownify(title)} class="mb-4" />
        {
          image && (
            <div class="mb-10 flex justify-center">
              <ImageMod
                src={image}
                height={500}
                width={1600}
                alt={alt_img || title}
                class="rounded object-contain max-w-[400px] w-full"
                format="webp"
              />
            </div>
          )
        }
        <ul class="mb-4">
          <li class="mr-4 inline-block">
            <FaRegUserCircle className={"mr-2 -mt-1 inline-block"} />
            {humanize(author)}
          </li>
          <li class="mr-4 inline-block">
            <FaRegFolder className={"mr-2 -mt-1 inline-block"} />
            {
              categories.map((category: string, index: number) => (
                <a href={`/categories/${slugify(category)}`}>
                  {humanize(category)}
                  {index !== categories.length - 1 && ","}
                </a>
              ))
            }
          </li>
          <li class="mr-4 inline-block">
            <FaRegClock className={"mr-2 -mt-1 inline-block"} />
            {dateFormat(date)}
          </li>
        </ul>
        <div class="content mb-10">
          <Content />
        </div>
        <div class="row items-start justify-between">
          <div class="mb-10 flex items-center lg:col-5 lg:mb-0">
            <h5 class="mr-3">Tags :</h5>
            <ul>
              {
                tags.map((tag: string) => (
                  <li class="inline-block">
                    <a
                      class="m-1 block rounded bg-light px-3 py-1 hover:bg-primary hover:text-white dark:bg-darkmode-light dark:hover:bg-darkmode-primary dark:hover:text-text-dark"
                      href={`/tags/${slugify(tag)}`}
                    >
                      {humanize(tag)}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="flex items-center lg:col-4">
            <h5 class="mr-3">Share :</h5>
            <Share
              className="social-icons"
              title={title}
              description={description}
              slug={post.id}
            />
          </div>
        </div>
        <Disqus className="mt-20" client:only="react" />

        {recommendedProducts.length > 0 && (
          <div class="mt-20 border-t border-border pt-10">
            <h2 class="h3 mb-8 text-center">Рекомендуемые товары</h2>
            <div class="row justify-center">
              {recommendedProducts.map((product) => (
                <div class="mb-8 md:col-6 lg:col-4">
                  <ProductCard product={product} />
                </div>
              ))}
            </div>
          </div>
        )}
      </article>
    </div>

    <!-- Related posts -->
    <div class="section pb-0">
      <h2 class="h3 mb-12 text-center">Related Posts</h2>
      <div class="row justify-center">
        {
          similarPosts.map((post) => (
            <div class="lg:col-4 md:col-6 mb-14">
              <BlogCard data={post} />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  h1 {
    @apply text-h3-sm md:text-h3;
  }
</style>

<script>
  import { addToCart } from "@/lib/cart";

  const initAddToCart = () => {
    const buttons = document.querySelectorAll("[data-add-to-cart]");
    buttons.forEach((button) => {
      if ((button as any)._cartInit) return;
      (button as any)._cartInit = true;

      button.addEventListener("click", () => {
        const id = (button as HTMLElement).dataset.addToCart;
        if (!id) return;
        const title = (button as HTMLElement).dataset.title || "";
        const price = Number((button as HTMLElement).dataset.price || 0);
        const qtyInput = document.querySelector(
          `[data-qty-input="${(button as HTMLElement).dataset.qtySource}"]`,
        ) as HTMLInputElement | null;
        const quantity = Math.max(1, Number(qtyInput?.value || 1));

        addToCart({ id, title, price, quantity });
        document.dispatchEvent(new CustomEvent("cart:item-added"));
      });
    });
  };

  initAddToCart();
  document.addEventListener("astro:after-swap", initAddToCart);
  document.addEventListener("astro:page-load", initAddToCart);
</script>
