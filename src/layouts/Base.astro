---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import {
  GoogleTagmanager,
  GoogleTagmanagerNoscript,
} from "@digi4care/astro-google-tagmanager";
import { Font } from "astro:assets";
import Announcement from "./helpers/Announcement";
import CartModal from "./helpers/CartModal";
import CheckoutModal from "./helpers/CheckoutModal";
import JsonLd from "@/components/JsonLd.astro";
import IconSprite from "@/components/IconSprite.astro";
import { getBreadcrumbs, getBreadcrumbSchema } from "@/lib/utils/breadcrumb";
import { SEO } from "astro-seo";

// font families - extract font names for Font component (filter out type keys)
const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type"),
);

// types for frontmatters
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  hideBreadcrumbs?: boolean;
}

// destructure frontmatter
const {
  title,
  meta_title,
  description,
  image,
  noindex,
  canonical,
  hideBreadcrumbs,
} = Astro.props;

const siteUrl = config.site.base_url.replace(/\/$/, "");
const currentPath = Astro.url.pathname.replace(/\/$/, "");
const autoCanonical =
  canonical ||
  `${siteUrl}${currentPath}${config.site.trailing_slash ? "/" : ""}`;

// Pagination handling for title and description to avoid duplicates
const paths = Astro.url.pathname.split("/").filter(Boolean);
const pageIndex = paths.indexOf("page");
const pageNum =
  pageIndex !== -1 && paths[pageIndex + 1] ? paths[pageIndex + 1] : null;
const paginationSuffix = pageNum ? ` - Страница ${pageNum}` : "";

const breadcrumbs = getBreadcrumbs(Astro.url.pathname, title);
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs);

const finalTitle = plainify(
  (meta_title ? meta_title : title ? title : config.site.title) +
    paginationSuffix,
);
const finalDescription = plainify(
  (description ? description : config.metadata.meta_description) +
    paginationSuffix,
);
---

<!doctype html>
<html lang="ru">
  <head>
    <!-- google tag manager -->
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanager id={config.google_tag_manager.gtm_id} />
      )
    }
    <SEO
      title={finalTitle}
      description={finalDescription}
      canonical={autoCanonical}
      noindex={noindex}
      nofollow={noindex}
      openGraph={{
        basic: {
          title: finalTitle,
          type: "website",
          image: `${config.site.base_url}${image ? image : config.metadata.meta_image}`,
          url: `${config.site.base_url}/${Astro.url.pathname.replace("/", "")}`,
        },
        optional: {
          description: finalDescription,
          locale: "ru_RU",
          siteName: config.site.title,
        },
      }}
      twitter={{
        card: "summary_large_image",
        title: finalTitle,
        description: finalDescription,
        image: `${config.site.base_url}${image ? image : config.metadata.meta_image}`,
      }}
      extend={{
        meta: [
          { name: "author", content: config.metadata.meta_author },
          { name: "theme-name", content: "astroplate" },
          { name: "msapplication-TileColor", content: "#000000" },
          {
            name: "theme-color",
            content: "#fff",
            media: "(prefers-color-scheme: light)",
          },
          {
            name: "theme-color",
            content: "#000",
            media: "(prefers-color-scheme: dark)",
          },
          { name: "generator", content: Astro.generator },
          {
            name: "viewport",
            content: "width=device-width, initial-scale=1, maximum-scale=5",
          },
          { httpEquiv: "Content-Type", content: "text/html; charset=UTF-8" },
        ],
        link: [
          {
            rel: "icon",
            type: "image/png",
            sizes: "48x48",
            href: "/images/favicon-48x48.png",
          },
          {
            rel: "icon",
            type: "image/png",
            sizes: "96x96",
            href: "/images/favicon-96x96.png",
          },
          {
            rel: "icon",
            type: "image/png",
            sizes: "144x144",
            href: "/images/favicon-144x144.png",
          },
          {
            rel: "icon",
            type: "image/png",
            sizes: "192x192",
            href: "/images/favicon-192x192.png",
          },
          {
            rel: "icon",
            type: "image/png",
            sizes: "512x512",
            href: "/images/favicon-512x512.png",
          },
          { rel: "shortcut icon", href: config.site.favicon },
        ],
      }}
    />

    <!-- google font css - Astro 6 built-in Font API -->
    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return <Font cssVariable={cssVar} preload={key === "primary"} />;
      })
    }

    <JsonLd
      type="WebSite"
      data={{
        name: config.site.title,
        url: config.site.base_url,
        description: config.metadata.meta_description,
        inLanguage: "ru-RU",
      }}
    />

    <JsonLd
      type="Organization"
      data={{
        name: "ЧАСТНОЕ ПРЕДПРИЯТИЕ «ТЕЛЕОФИС»",
        url: config.site.base_url,
        logo: `${config.site.base_url}${config.site.favicon}`,
        image: `${config.site.base_url}/images/og-image.png`,
        address: {
          "@type": "PostalAddress",
          streetAddress: "ул. Макаёнка, 12г, пом. 257",
          addressLocality: "Минск",
          postalCode: "220114",
          addressCountry: "BY",
        },
        contactPoint: {
          "@type": "ContactPoint",
          telephone: "+375298462462",
          contactType: "customer service",
        },
        sameAs: ["https://t.me/teleofis24"],
      }}
    />

    {
      !hideBreadcrumbs && (
        <JsonLd type="BreadcrumbList" data={breadcrumbSchema} />
      )
    }

    <slot name="head" />
  </head>
  <body class="flex flex-col min-h-screen">
    {/* google tag manager noscript */}
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanagerNoscript id={config.google_tag_manager.gtm_id} />
      )
    }
    <Announcement client:idle />
    <Header />
    <CartModal client:idle />
    <CheckoutModal client:idle />
    <main class="grow" id="main-content">
      {/* Breadcrumbs rendered in individual pages */}
      <slot />
    </main>
    <Footer />
    <TwSizeIndicator />
    <IconSprite />
  </body>
</html>
