---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import {
  GoogleTagmanager,
  GoogleTagmanagerNoscript,
} from "@digi4care/astro-google-tagmanager";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import Announcement from "./helpers/Announcement";
import CartModal from "./helpers/CartModal";
import CheckoutModal from "./helpers/CheckoutModal";
import SearchModal from "./helpers/SearchModal";
import JsonLd from "@/components/JsonLd.astro";

// font families - extract font names for Font component (filter out type keys)
const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type"),
);

// types for frontmatters
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  hideBreadcrumbs?: boolean;
}

// destructure frontmatter
const { title, meta_title, description, image, noindex, canonical } =
  Astro.props;

const siteUrl = config.site.base_url.replace(/\/$/, "");
const currentPath = Astro.url.pathname.replace(/\/$/, "");
const autoCanonical = canonical || `${siteUrl}${currentPath}${config.site.trailing_slash ? "/" : ""}`;

// Pagination handling for title and description to avoid duplicates
const paths = Astro.url.pathname.split("/").filter(Boolean);
const pageIndex = paths.indexOf("page");
const pageNum = pageIndex !== -1 && paths[pageIndex + 1] ? paths[pageIndex + 1] : null;
const paginationSuffix = pageNum ? ` - Страница ${pageNum}` : "";

const finalTitle = plainify(
  (meta_title ? meta_title : title ? title : config.site.title) + paginationSuffix
);
const finalDescription = plainify(
  (description ? description : config.metadata.meta_description) + paginationSuffix
);
---

<!doctype html>
<html lang="ru">
  <head>
    <!-- google tag manager -->
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanager id={config.google_tag_manager.gtm_id} />
      )
    }
    <!-- favicon -->
    <link rel="icon" type="image/png" sizes="48x48" href="/images/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="144x144" href="/images/favicon-144x144.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/favicon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512x512.png" />
    <link rel="shortcut icon" href={config.site.favicon} />
    <!-- theme meta -->
    <meta name="theme-name" content="astroplate" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- google font css - Astro 6 built-in Font API -->
    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return <Font cssVariable={cssVar} preload />;
      })
    }

    <!-- responsive meta -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <!-- title -->
    <title>{finalTitle}</title>

    <!-- canonical url -->
    <link rel="canonical" href={autoCanonical} item-prop="url" />

    <!-- noindex robots -->
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- meta-description -->
    <meta name="description" content={finalDescription} />

    <ClientRouter />

    <!-- author from config.json -->
    <meta name="author" content={config.metadata.meta_author} />

    <!-- og-title -->
    <meta property="og:title" content={finalTitle} />

    <!-- og-description -->
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={`${config.site.base_url}/${Astro.url.pathname.replace("/", "")}`}
    />

    <!-- twitter-title -->
    <meta
      name="twitter:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title,
      )}
    />

    <!-- twitter-description -->
    <meta
      name="twitter:description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />

    <!-- og-image -->
    <meta
      property="og:image"
      content={`${config.site.base_url}${
        image ? image : config.metadata.meta_image
      }`}
    />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content={config.site.title} />

    <!-- twitter-image -->
    <meta
      name="twitter:image"
      content={`${config.site.base_url}${
        image ? image : config.metadata.meta_image
      }`}
    />
    <meta name="twitter:card" content="summary_large_image" />

    <JsonLd
      type="Organization"
      data={{
        name: "ЧАСТНОЕ ПРЕДПРИЯТИЕ «ТЕЛЕОФИС»",
        url: config.site.base_url,
        logo: `${config.site.base_url}${config.site.favicon}`,
        image: `${config.site.base_url}/images/og-image.png`,
        address: {
          "@type": "PostalAddress",
          streetAddress: "ул. Макаёнка, 12г, пом. 257",
          addressLocality: "Минск",
          postalCode: "220114",
          addressCountry: "BY"
        },
        contactPoint: {
          "@type": "ContactPoint",
          telephone: "+375298462462",
          contactType: "customer service"
        },
        sameAs: [
          "https://t.me/teleofis24"
        ]
      }}
    />
    <slot name="head" />
  </head>
  <body class="flex flex-col min-h-screen">
    {/* google tag manager noscript */}
    {
      config.google_tag_manager.enable && (
        <GoogleTagmanagerNoscript id={config.google_tag_manager.gtm_id} />
      )
    }
    <Announcement client:only="react" />
    <Header />
    <SearchModal client:only="react" />
    <CartModal client:only="react" />
    <CheckoutModal client:only="react" />
    <main class="grow" id="main-content">
      {/* Breadcrumbs rendered in individual pages */}
      <slot />
    </main>
    <Footer />
    <TwSizeIndicator />
  </body>
</html>
