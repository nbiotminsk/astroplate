---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { humanize } from "@/lib/utils/textConverter";

const { title = "", compact = false }: { title?: string; compact?: boolean } =
  Astro.props;
---

<section>
  <div class="container text-center">
    <div
      class:list={[
        "rounded-2xl bg-linear-to-b from-body to-light px-8 dark:from-darkmode-body dark:to-darkmode-light",
        compact ? "py-5" : "py-14",
      ]}
    >
      <h1 set:text={humanize(title)} />
      <Breadcrumbs className={compact ? "mt-3" : "mt-6"} title={title} />
    </div>
  </div>
</section>

<style>
  h1 {
    @apply text-h3-sm md:text-h3;
  }
</style>
