---
import siteContent from "@/config/siteContent.json";

const { footer } = siteContent;
---

<footer
  class="bg-light dark:bg-darkmode-light border-t border-border dark:border-darkmode-border"
>
  <div class="container py-12">
    <div class="row gap-y-8">
      {
        footer.columns.map((column) => (
          <div class="sm:col-6 lg:col-3">
            <h3 class="mb-4 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark">
              {column.title}
            </h3>
            <ul class="space-y-2">
              {column.links.map((link) => (
                <li>
                  <a href={link.href} class="hover:underline">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div class="sm:col-6 lg:col-3">
        <h3
          class="mb-4 text-lg font-semibold text-text-dark dark:text-darkmode-text-dark"
        >
          {footer.contacts.title}
        </h3>
        <ul class="space-y-2">
          {
            footer.contacts.items.map((item) => (
              <li>
                {item.href ? (
                  <a
                    href={item.href}
                    target={item.external ? "_blank" : undefined}
                    rel={item.external ? "noopener" : undefined}
                    class="hover:underline"
                  >
                    {item.label}
                  </a>
                ) : (
                  item.label
                )}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <div
    class="border-t border-border py-6 text-center text-sm dark:border-darkmode-border"
  >
    {footer.copyright}
  </div>
</footer>
