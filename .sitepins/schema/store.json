    {
      "name": "price",
      "label": "Цена",
      "type": "string",
      "defaultValue": "0"
    },
    {
      "name": "price_currency",
      "label": "Валюта",
      "type": "string",
      "defaultValue": "BYN"
    },
    {
      "name": "img",
      "label": "Изображение",
      "type": "media"
    },
    {
      "name": "brand",
      "label": "Бренд",
      "type": "string",
      "defaultValue": "Teleofis"
    },
    {
      "name": "availability",
      "label": "В наличии",
      "type": "boolean",
      "defaultValue": true
