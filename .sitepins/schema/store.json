      "label": "Особенности",
      "type": "Array",
      "subType": "string"
    },
    {
      "name": "condition",
      "label": "Состояние",
      "type": "string",
      "defaultValue": "https://schema.org/NewCondition"
    },
    {
      "name": "custom_label_0",
      "label": "Метка товара",
      "type": "select",
      "options": [
        "standart",
        "premium",
        "discount"
      ],
      "defaultValue": "standart"
    },
    {
      "name": "sku",
      "label": "Артикул (SKU)",
      "type": "string"
    },
    {
      "name": "faq",
      "label": "Вопросы и ответы (FAQ)",
