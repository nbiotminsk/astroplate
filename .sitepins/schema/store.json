      "fields": [
        {
          "name": "question",
          "label": "Вопрос",
          "type": "string"
        },
        {
          "name": "answer",
          "label": "Ответ",
          "type": "string"
        }
      ]
    },
    {
      "name": "draft",
      "label": "Черновик",
      "type": "boolean",
      "defaultValue": false
