    {
      "name": "shippingDetails",
      "label": "Shipping Details",
      "type": "object",
      "isIgnored": false,
      "fields": [
        {
          "name": "weight",
          "label": "Weight (kg)",
          "type": "number",
          "value": 0.5,
          "isIgnored": false,
          "defaultValue": "0.5"
        }
      ]
    },
    {
      "name": "hasMerchantReturnPolicy",
      "label": "Merchant Return Policy",
      "type": "object",
      "isIgnored": false,
      "fields": [
        {
          "name": "returnPeriod",
          "label": "Return Period (e.g. P14D)",
          "type": "string",
          "value": "P14D",
          "isIgnored": false,
          "defaultValue": "P14D"
        }
      ]
